// Phase 6: GADT (广义代数数据类型) 测试
// 文档 §2.13: 构造器用 `: ReturnType` 标注返回类型；match 时类型细化

// GADT 定义：每个构造器通过 `:` 标注其返回的具体类型参数
type Expr<T> =
    | IntLit(i32)                       : Expr<i32>
    | BoolLit(bool)                     : Expr<bool>
    | Add(Expr<i32>, Expr<i32>)         : Expr<i32>
    | If(Expr<bool>, Expr<T>, Expr<T>)  : Expr<T>

// 类型细化：match 各分支推导局部类型等式（IntLit => T~i32, BoolLit => T~bool）
// 因此 IntLit(n) 的 n : i32，BoolLit(b) 的 b : bool，各分支返回类型可不同
fun eval_expr<T>(expr: Expr<T>) : T {
    match expr {
        IntLit(n) => n,                                  // T ~ i32，n : i32
        BoolLit(b) => b,                                 // T ~ bool，b : bool
        Add(a, b) => eval_expr(a) + eval_expr(b),        // T ~ i32
        If(cond, then, els) =>
            if eval_expr(cond) { eval_expr(then) } else { eval_expr(els) },
    }
}

fun main() {
    // Add: (3 + 4) = 7
    println(eval_expr(Add(IntLit(3), IntLit(4))))

    // BoolLit: true
    println(eval_expr(BoolLit(true)))

    // If(true, 1, 2) = 1
    println(eval_expr(If(BoolLit(true), IntLit(1), IntLit(2))))

    // If(false, 10, 20) = 20
    println(eval_expr(If(BoolLit(false), IntLit(10), IntLit(20))))

    // 嵌套：Add(If(true, 5, 6), IntLit(100)) = 105
    println(eval_expr(Add(If(BoolLit(true), IntLit(5), IntLit(6)), IntLit(100))))

    println("Phase 6: All tests passed!")
}
