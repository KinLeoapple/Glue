fun safeCompute(x: i32): Throw<i32, Error> {
    if (x < 0) { throw Error("negative") }
    Ok(x * 2)
}

val sc1 = match safeCompute(10) {
    Ok(v) => v
    Error(e) => -1
}
println(sc1)

val sc2 = match safeCompute(0) {
    Ok(v) => v
    Error(e) => -1
}
println(sc2)

val sc3 = match safeCompute(-5) {
    Ok(v) => v
    Error(e) => -1
}
println(sc3)

// ============================================================
// 99. 多层 ? 传播 — Throw 链
// ============================================================

fun step1b(): Throw<i32, Error> { Ok(10) }
fun step2b(x: i32): Throw<i32, Error> {
    if (x > 5) { Ok(x * 2) } else { throw Error("too small") }
}

fun pipeline2(): Throw<i32, Error> {
    val a = step1b()?
    val b = step2b(a)?
    b + 1
}

val pipe2_result = match pipeline2() {
    Ok(v) => v
    Error(e) => -1
}
println(pipe2_result)

// ============================================================
// 100. 泛型 ADT — 更多模式匹配
// ============================================================

fun listLength(l: List<i32>): i32 {
    match l {
        Nil => 0
        Cons(_, tail) => 1 + listLength(tail)
    }
}
println(listLength(Nil))
println(listLength(Cons(1, Cons(2, Cons(3, Nil)))))

