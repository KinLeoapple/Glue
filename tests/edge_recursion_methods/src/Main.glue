// Recursion depth + string/array method edges (regression for fixes)

// non-tail recursion within safe depth
fun sumTo(n: i32): i32 {
    if (n == 0) { 0 } else { n + sumTo(n - 1) }
}

// tail recursion uses TCO — no stack growth
fun countTo(n: i32, acc: i32): i32 {
    if (n == 0) { acc } else { countTo(n - 1, acc + 1) }
}

// nested non-tail recursion (Ackermann)
fun ack(m: i32, n: i32): i32 {
    if (m == 0) { n + 1 }
    else if (n == 0) { ack(m - 1, 1) }
    else { ack(m - 1, ack(m, n - 1)) }
}

fun main() {
    // ---- recursion within safe depth ----
    println(sumTo(100))        // 5050
    println(sumTo(150))        // 11325

    // ---- tail recursion goes deep without overflow ----
    println(countTo(50000, 0)) // 50000

    // ---- nested non-tail recursion ----
    println(ack(2, 3))         // 9
    println(ack(3, 3))         // 61

    // ---- is_empty works on both arrays and strings ----
    val ea: i32[] = []
    println(ea.is_empty())     // true
    println([1].is_empty())    // false
    println("".is_empty())     // true
    println("x".is_empty())    // false

    // ---- empty array methods return null, not crash ----
    println(ea.first())        // null
    println(ea.last())         // null
    println(ea.pop())          // null
    println(ea.drop_last())    // []

    // ---- unicode string indexing ----
    val u = "héllo你好"
    println(u.len())           // 7
    println(u[1])              // é
    println(u[5])              // 你

    println("edge_recursion_methods: All tests passed!")
}
