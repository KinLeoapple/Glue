// Phase 1 功能验证

// ============================================================
// 1. 基础类型
// ============================================================
val a = 42
val b = 3.14
val c = true
val ch = 'A'
println(a)
println(b)
println(c)
println(ch)

// 整数类型后缀
val i8_val = 127i8
val u8_val = 255u8
val i64_val = 9999999999i64
println(i8_val)
println(u8_val)
println(i64_val)

// ============================================================
// 2. Nullable
// ============================================================
val x: i32? = null
val y = x ?? 99
println(y)

val z: i32? = 10
val w = z ?? 99
println(w)

// 非空断言 !
val nz: i32? = 42
val nv = nz!
println(nv)

// 安全访问 ?.
val nullable_point: (x: i32, y: i32)? = null
val safe_x = nullable_point?.x
println(safe_x)

// ============================================================
// 3. Ok/Error 和 Throw
// ============================================================
val result = Ok(42)
println(result)

val err = Error("something failed")
println(err)

// throw 语句
fun mightFail(x: i32): Throw<i32, Error> {
    if (x < 0) {
        throw Error("negative value")
    }
    Ok(x * 2)
}
println(mightFail(5))

// ============================================================
// 4. match Ok/Error
// ============================================================
val r = match Ok(100) {
    Ok(v) => v + 1
    Error(e) => 0
}
println(r)

// ============================================================
// 5. 自定义错误类型
// ============================================================
type FileError = Error("file error")
val fe = FileError("config.json not found")
println(fe)

// ============================================================
// 6. 字符串插值
// ============================================================
val name = "Glue"
println("Hello, {name}!")
// 转义花括号
println("Use {{ and }} for braces")

// ============================================================
// 7. defer
// ============================================================
var counter = 0
{
    counter = 1
    defer counter = 10
    println(counter)
}
println(counter)

// 多个 defer LIFO 顺序
var order = ""
{
    defer order = order + "A"
    defer order = order + "B"
    defer order = order + "C"
}
println(order)

// ============================================================
// 8. TCO - 尾递归
// ============================================================
fun sum(n: i32, acc: i32): i32 {
    if (n == 0) { acc } else { sum(n - 1, acc + n) }
}
println(sum(1000, 0))

// TCO - 斐波那契（非尾递归，验证 TCO 不误优化）
fun fib(n: i32): i32 {
    if (n <= 1) { n } else { fib(n - 1) + fib(n - 2) }
}
println(fib(10))

// ============================================================
