fun nestedMatch(x: i32, y: i32): str {
    match x {
        0 => "zero"
        _ => match y {
            0 => "x nonzero, y zero"
            _ => "both nonzero"
        }
    }
}
println(nestedMatch(0, 0))
println(nestedMatch(1, 0))
println(nestedMatch(1, 1))

