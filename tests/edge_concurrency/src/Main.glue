// Edge cases: concurrency — async functions, atomic ops, channel buffer/close, select

// async 函数：调用返回 Async<T>
async fun mul10x10(): i64 { 10 * 10 }
async fun add20x5(): i64 { 20 + 5 }
async fun sub100x1(): i64 { 100 - 1 }
async fun addX50(x: i64): i64 { x + 50 }
async fun incrCounter(c: Atomic<i64>): Unit { c = c + 1 }
async fun produceResult(ch: Channel<i64>): Unit { ch.send(12345) }
async fun mul7x7(): i64 { 7 * 7 }

fun main() {
    // ---- multiple async calls, independent results ----
    val s1 = mul10x10()
    val s2 = add20x5()
    val s3 = sub100x1()
    println(s1.await())   // 100
    println(s2.await())   // 25
    println(s3.await())   // 99

    // ---- async captures by deep copy: outer var unchanged ----
    var x = 0
    val s4 = addX50(x)
    println(s4.await())   // 50
    println(x)            // 0 (unchanged)

    // ---- atomic shared across async ----
    var counter = atomic 0i64
    val a1 = incrCounter(counter)
    a1.await()
    val a2 = incrCounter(counter)
    a2.await()
    println(counter)      // 2

    // ---- atomic swap and cas ----
    var atm = atomic 10
    println(atm.swap(20))   // 10 (old value)
    println(atm)            // 20
    println(atm.cas(20, 30)) // true
    println(atm)            // 30
    println(atm.cas(99, 40)) // false
    println(atm)            // 30 (unchanged)

    // ---- channel: buffered send/recv ordering (FIFO) ----
    val ch = channel(10)
    ch.send(1)
    ch.send(2)
    ch.send(3)
    println(ch.recv())    // 1
    println(ch.recv())    // 2
    println(ch.recv())    // 3

    // ---- channel: close, then drain buffer, then null ----
    val ch2 = channel(10)
    ch2.send(100)
    ch2.send(200)
    ch2.sender.close()
    println(ch2.recv())   // 100
    println(ch2.recv())   // 200
    println(ch2.recv())   // null (closed + drained)

    // ---- channel: sender/receiver split ----
    val ch3 = channel(10)
    val tx = ch3.sender
    val rx = ch3.receiver
    tx.send(42)
    tx.send(43)
    println(rx.recv())    // 42
    println(rx.recv())    // 43
    tx.close()

    // ---- select with ready channel ----
    val cha = channel(10)
    val chb = channel(10)
    chb.send(999)
    select {
        cha.recv() => println("from-a")
        chb.recv() => println("from-b")
    }

    // ---- select binding the received value (ch.recv() => name => body) ----
    val chc = channel(10)
    chc.send(7)
    select {
        chc.recv() => v => println("got " + cast(v).to(str))
    }

    // ---- async computing into channel ----
    val result_ch = channel(10)
    val producer = produceResult(result_ch)
    producer.await()
    println(result_ch.recv())   // 12345

    // ---- many atomic increments via sequential async calls ----
    var acc = atomic 0i64
    var i = 0
    while i < 10 {
        val sp = incrCounter(acc)
        sp.await()
        i = i + 1
    }
    println(acc)   // 10

    // ---- async status query ----
    val s5 = mul7x7()
    val r5 = s5.await()
    println(s5.status())   // completed/done status
    println(r5)            // 49

    println("edge_concurrency: All tests passed!")
}
