// ============================================================
// 43. ADT — 递归列表更多操作
// ============================================================

fun listReverse(l: List): List {
    fun helper(remaining, acc): List {
        match remaining {
            Nil => acc
            Cons(head, tail) => helper(tail, Cons(head, acc))
        }
    }
    helper(l, Nil)
}

val rev = listReverse(Cons(1, Cons(2, Cons(3, Nil))))
println(rev)

// ============================================================
// 44. ADT — 列表包含检查
// ============================================================

fun listContains(l: List, target: i32): bool {
    match l {
        Nil => false
        Cons(head, tail) => if (head == target) { true } else { listContains(tail, target) }
    }
}

println(listContains(Cons(1, Cons(2, Cons(3, Nil))), 2))
println(listContains(Cons(1, Cons(2, Cons(3, Nil))), 5))

