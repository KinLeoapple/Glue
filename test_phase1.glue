// Nullable 嵌套在 Throw 中
fun findOrError2(id: i32): Throw<str, Error> {
    if (id < 0) {
        throw Error("invalid id")
    }
    if (id == 0) {
        Ok("")
    } else {
        Ok("user" + str(id))
    }
}

val r6 = match findOrError2(-1) {
    Ok(v) => v
    Error(e) => "error"
}
println(r6)

val r7 = match findOrError2(0) {
    Ok(v) => v
    Error(e) => "error"
}
println(r7)

val r8 = match findOrError2(5) {
    Ok(v) => v
    Error(e) => "error"
}
