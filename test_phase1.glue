// 146. 函数 — 函数作为参数传递给高阶函数
// ============================================================

fun applyTwice(f, x) { f(f(x)) }
println(applyTwice(fun(x) { x + 1 }, 5))
println(applyTwice(fun(x) { x * 2 }, 3))

// ============================================================
// 147. 泛型 ADT — 泛型 Maybe 类型
// ============================================================

type Maybe<T> =
    | Nothing
    | Just(T)

val just_val = Just(42)
val nothing_val = Nothing

fun maybeOrDefault(m: Maybe<i32>, default: i32): i32 {
    match m {
        Nothing => default
        Just(v) => v
    }
}

println(maybeOrDefault(just_val, 0))
println(maybeOrDefault(nothing_val, 0))

// ============================================================
// 148. 泛型 ADT — 泛型 Either 类型
// ============================================================

// 注：Either 使用 Left/Right 可能与内建类型冲突
// 改用不同的构造器名称
type Result<T, E> =
    | Success(T)
    | Failure(E)

val success_val: Result<i32, str> = Success(42)
val failure_val: Result<i32, str> = Failure("error")

fun resultToInt(r: Result<i32, str>): i32 {
    match r {
        Success(v) => v
        Failure(msg) => -1
    }
}

println(resultToInt(success_val))
println(resultToInt(failure_val))

// ============================================================
// 149. Newtype — newtype 内部值提取
// ============================================================

type Grade = Grade(i32)

val g1 = Grade(85)
val g2 = Grade(60)

fun extractGrade(gr: Grade): i32 {
    match gr {
        Grade(v) => v
    }
}

println(extractGrade(g1))
println(extractGrade(g2))

// ============================================================
// 150. 字符串 — 字符串比较运算
// ============================================================

println("abc" == "abc")
println("abc" != "def")
println("apple" < "banana")

// ============================================================
// 151. 数组 — 数组元素求和与查找
// ============================================================

val search_arr = [5, 10, 15, 20, 25]
var search_sum = 0
for v in search_arr {
    search_sum = search_sum + v
}
println(search_sum)
println(search_arr.contains(15))
println(search_arr.contains(99))

// ============================================================
// 152. Nullable — 三元替代（if-else 表达式）
// ============================================================

fun clamp(v: i32, min_v: i32, max_v: i32): i32 {
    if (v < min_v) { min_v }
    else if (v > max_v) { max_v }
    else { v }
}

println(clamp(-5, 0, 10))
println(clamp(5, 0, 10))
println(clamp(15, 0, 10))
