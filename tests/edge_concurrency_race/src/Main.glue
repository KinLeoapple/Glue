// Concurrency under real parallel contention + generic-array types

// async 函数：调用返回 Async<T>，实参深拷贝；Atomic 实参共享底层内存
async fun incrOne(c: Atomic<i32>): Unit { c += 1 }
async fun addTwo(s: Atomic<i32>): Unit { s += 2 }
async fun subTwo(s: Atomic<i32>): Unit { s -= 2 }
async fun ret7(): i32 { 7 }

fun main() {
    // ---- 100 async calls incrementing a shared atomic in parallel ----
    var counter = atomic 0
    var handles: Async<()>[] = []
    for i in 1..=100 {
        val c = counter
        handles = handles ++ [incrOne(c)]
    }
    for h in handles { h.await() }
    println(counter)          // 100 (no lost updates)

    // ---- mixed add/sub nets to zero ----
    var sum = atomic 0
    var hs: Async<()>[] = []
    for i in 1..=50 {
        val s = sum
        hs = hs ++ [addTwo(s)]
    }
    for i in 1..=50 {
        val s = sum
        hs = hs ++ [subTwo(s)]
    }
    for h in hs { h.await() }
    println(sum)              // 0

    // ---- generic-typed array of async handles parses and works ----
    var results: Async<i32>[] = []
    for i in 1..=5 {
        results = results ++ [ret7()]
    }
    var total = 0
    for r in results {
        total = total + r.await()
    }
    println(total)            // 35

    println("edge_concurrency_race: All tests passed!")
}
