// Closure capture edges: var sharing, escape, independence, nested, loop capture

type IntFn = () -> i32

// escaping closure capturing mutable state (counter factory)
fun makeCounter(): IntFn {
    var n: i32 = 0
    fun() {
        n = n + 1
        n
    }
}

fun main() {
    // ---- capture var by reference: external mutation visible ----
    var x: i32 = 10
    val read = fun() { x }
    x = 20
    println(read())          // 20

    // ---- closure mutates captured var, visible outside ----
    var y: i32 = 0
    val inc = fun() { y = y + 1 }
    inc()
    inc()
    println(y)               // 2

    // ---- nested closures share the same captured var ----
    var count: i32 = 0
    val outer = fun() {
        val inner = fun() { count = count + 1 }
        inner()
        inner()
    }
    outer()
    outer()
    println(count)           // 4

    // ---- escaping closure: captured state persists after return ----
    val c = makeCounter()
    println(c())             // 1
    println(c())             // 2
    println(c())             // 3

    // ---- two counters are independent ----
    val a = makeCounter()
    val b = makeCounter()
    println(a())             // 1
    println(a())             // 2
    println(b())             // 1 (independent of a)

    // ---- loop-variable capture: each closure captures its own value ----
    var fns: IntFn[] = []
    var i: i32 = 1
    while i <= 3 {
        val captured: i32 = i
        fns = fns ++ [fun() { captured }]
        i = i + 1
    }
    // 逐个调用验证每个闭包捕获独立值
    val f0: IntFn = fns[0]
    val f1: IntFn = fns[1]
    val f2: IntFn = fns[2]
    println(f0())  // 1
    println(f1())  // 2
    println(f2())  // 3 (not all 3)

    // ---- nullary function type () -> T annotation ----
    val g: () -> i32 = fun() { 42i32 }
    println(g())             // 42

    println("edge_closures: All tests passed!")
}
