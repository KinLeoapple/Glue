// 测试浮点溢出检查

// 测试 1: f32 字面量溢出（应该在编译时拒绝）
// let huge = 1e100f32;  // 这个会超出 f32 范围

// 测试 2: f32 运算溢出
fn test_f32_overflow() {
    let max = 3.4e38f32;
    let result = max * 2.0f32;  // 应该溢出
    println("Result: {}", result);
}

// 测试 3: f16 溢出（f16 范围更小）
fn test_f16_overflow() {
    let max = 65000.0f16;
    let result = max * 2.0f16;  // 应该溢出
    println("Result: {}", result);
}

// 测试 4: 正常的 f64 运算（不溢出）
fn test_f64_normal() {
    let a = 1.5e100f64;
    let b = 2.0f64;
    let result = a * b;
    println("f64 result: {}", result);
}

// 测试 5: 浮点取负溢出
fn test_negate_overflow() {
    let max = 3.4e38f32;
    let result = -max;  // 取负不应该溢出（对称）
    println("Negated: {}", result);
}

test_f32_overflow();
// test_f16_overflow();
// test_f64_normal();
// test_negate_overflow();
