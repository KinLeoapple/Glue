// ============================================================
// 121. 嵌套函数 — 多层嵌套
// ============================================================

fun outer2(x: i32): i32 {
    fun middle(y: i32): i32 {
        fun innermost(z: i32): i32 {
            x + y + z
        }
        innermost(100)
    }
    middle(10)
}
println(outer2(1))

// 嵌套函数访问外层局部变量
fun makeCounter(start: i32): i32 {
    var count = start
    fun increment(): i32 {
        count = count + 1
        count
    }
    increment()
    increment()
    increment()
}
println(makeCounter(0))

