// 文档 §4.6.2: 文件模块作为 Trait 值。
// Memory 模块提供 put/get，结构化满足 Store trait（§2.12.2 结构化子类型）。
// 多出的 delete 方法不影响（方法多的模块 <: 方法少的 Trait）。
pub fun put(key: str, value: str) : Unit {
    println("[Memory] put " + key + " = " + value)
}

pub fun get(key: str) : str {
    "[Memory] value-of-" + key
}

pub fun delete(key: str) : Unit {
    println("[Memory] delete " + key)
}
