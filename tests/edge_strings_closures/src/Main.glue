// Edge cases: strings (unicode/escapes/interpolation), closures (capture), recursion (deep/mutual/TCO)

// mutual recursion
fun isEven(n: i32): bool {
    if n == 0 { true } else { isOdd(n - 1) }
}
fun isOdd(n: i32): bool {
    if n == 0 { false } else { isEven(n - 1) }
}

// deep tail recursion (should not stack overflow with TCO)
fun countTo(n: i32, acc: i32): i32 {
    if n == 0 { acc } else { countTo(n - 1, acc + 1) }
}

// closure returning closure (currying)
fun adder(x: i32) {
    fun(y: i32) { x + y }
}

// closure capturing a loop variable via accumulation
fun makeClosures(): i32 {
    var total = 0
    var i = 0
    while i < 5 {
        val captured = i
        val f = fun() { captured }
        total = total + f()
        i = i + 1
    }
    total
}

// higher-order: compose a list of operations
fun applyAll(x: i32, f, g, h): i32 {
    h(g(f(x)))
}

// recursion building a string
fun repeat(s: str, n: i32): str {
    if n <= 0 { "" } else { s + repeat(s, n - 1) }
}

fun main() {
    // ---- unicode strings ----
    val cn = "你好世界"
    println(cn.len())          // 4 scalar values
    val emoji = "héllo"
    println(emoji.len())       // 5
    val mixed = "a你b好c"
    println(mixed.len())       // 5

    // ---- escape sequences ----
    println("tab\tend")
    println("nl\nend")
    println("quote\"end")
    println("backslash\\end")
    println("carriage\rend")

    // ---- interpolation: nested expressions ----
    val x: i32 = 10
    val y: i32 = 20
    println("sum={x + y}")            // sum=30
    println("prod={x * y}")           // prod=200
    println("nested={x + y * 2}")     // nested=50
    println("compare={x < y}")        // compare=true
    println("call={repeat("ab", 2)}") // call=abab

    // ---- interpolation: escaped braces ----
    println("literal {{braces}}")     // literal {braces}
    println("{{x}} is {x}")           // {x} is 10

    // ---- string concatenation chains ----
    val parts = "a" + "b" + "c" + "d" + "e"
    println(parts)                    // abcde
    println(parts.len())              // 5

    // ---- string indexing ----
    val word = "hello"
    println(word[0])   // h
    println(word[4])   // o

    // ---- string comparison ----
    println("apple" < "banana")  // true
    println("zebra" > "apple")   // true
    println("same" == "same")    // true

    // ---- empty string ----
    println("".len())            // 0
    println("" + "x")            // x

    // ---- mutual recursion ----
    println(isEven(10))   // true
    println(isOdd(10))    // false
    println(isEven(7))    // false
    println(isOdd(7))     // true

    // ---- deep tail recursion ----
    println(countTo(10000, 0))    // 10000
    println(countTo(100000, 0))   // 100000

    // ---- closure: currying ----
    val add5 = adder(5)
    val add100 = adder(100)
    println(add5(3))      // 8
    println(add100(3))    // 103
    val add7 = adder(7)
    println(add7(8))      // 15

    // ---- closure: captured loop values ----
    println(makeClosures())  // 0+1+2+3+4 = 10

    // ---- higher-order composition ----
    println(applyAll(2, fun(n) { n + 1 }, fun(n) { n * 3 }, fun(n) { n - 2 }))  // ((2+1)*3)-2 = 7

    // ---- recursion building string ----
    println(repeat("xy", 3))   // xyxyxy
    println(repeat("z", 0))    // (empty)

    // ---- closure capturing and mutating outer var ----
    var counter = 0
    val inc = fun() { counter = counter + 1 }
    inc()
    inc()
    inc()
    println(counter)   // 3

    // ---- closure over multiple captured vars ----
    val base = 1000
    val rate = 5
    val compute = fun(n) { base + n * rate }
    println(compute(10))  // 1050
    println(compute(0))   // 1000

    println("edge_strings_closures: All tests passed!")
}
