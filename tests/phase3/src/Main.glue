// Phase 3 逐步测试

// 1. 记录宽度子类型
fun greet(user: (name: str)) : str {
    "Hello, " + user.name
}

// 2. 记录扩展
// 3. 记录更新

// 4. Error 子类型
type FileError: Error = FileError(msg: str) {
    override fun prefix(self): str {
        "file error"
    }
}

type NetworkError: Error = NetworkError(msg: str) {
    override fun prefix(self): str {
        "network error"
    }
}

fun read_file(path: str) : Throw<str, FileError> {

    throw FileError(path + " not found")
}

// 5. Error 子类型传递
fun handle_error(result: Throw<str, Error>) : str {
    match result {
        Ok(content) => content,
        Error(e) => "error: " + e.message(),
    }
}

// 7. 多种错误类型
type ParseError: Error = ParseError(msg: str) {
    override fun prefix(self): str {
        "parse error"
    }
}

fun parse_int(s: str) : Throw<i32, ParseError> {
    throw ParseError("invalid integer: " + s)
}

fun handle_int_error(result: Throw<i32, Error>) : str {
    match result {
        Ok(val) => str(val),
        Error(e) => "error: " + e.message(),
    }
}

// 9. 记录模式匹配
fun describe_point(pt: (x: i32, y: i32)) : str {
    match pt {
        (x: 0, y: 0) => "origin",
        (x: px, y: py) => "point at (" + str(px) + ", " + str(py) + ")",
    }
}

// 10. 综合测试
fun make_user(name: str, age: i32) : (name: str, age: i32) {
    (name: name, age: age)
}

fun celebrate_birthday(user: (name: str, age: i32)) : (name: str, age: i32) {
    (...user, age: user.age + 1)
}

fun main() {
    // 1. 记录宽度子类型
    val full_user = (name: "Alice", age: 30)
    println(greet((name: full_user.name)))

    // 2. 记录扩展
    val base = (name: "Alice", age: 30)
    val extended = (...base, email: "alice@test.com")
    println(extended.name)
    println(extended.age)
    println(extended.email)

    // 3. 记录更新
    val updated = (...base, age: 31)
    println(updated.name)
    println(updated.age)

    // 4. Error 子类型
    val file_result = read_file("test.txt")
    match file_result {
        Ok(content) => println("ok: " + content),
        Error(e) => println("err: " + e.message()),
    }

    // 5. Error 子类型传递
    val handled = handle_error(file_result)
    println(handled)

    // 6. 自定义错误消息
    val fe = FileError("config.json missing")
    println(fe.message())

    val ne = NetworkError("timeout")
    println(ne.message())

    // 7. 多种错误类型
    val parse_result = parse_int("abc")
    val parse_handled = handle_int_error(parse_result)
    println(parse_handled)

    // 8. 链式记录操作
    val step1 = (x: 1, y: 2)
    val step2 = (...step1, z: 3)
    val step3 = (...step2, y: 20)
    println(step3.x)
    println(step3.y)
    println(step3.z)

    // 9. 记录模式匹配
    val origin = (x: 0i32, y: 0i32)
    println(describe_point(origin))

    val pt = (x: 3i32, y: 4i32)
    println(describe_point(pt))

    // 宽度子类型
    val pt3d = (x: 1i32, y: 2i32, z: 3i32)
    println(describe_point((x: pt3d.x, y: pt3d.y)))

    // 10. 综合测试
    val user1 = make_user("Eve", 28)
    val user_with_email = (...user1, email: "eve@test.com")
    println(user_with_email.name)
    println(user_with_email.age)
    println(user_with_email.email)

    val birthday_user = celebrate_birthday(user1)
    println(birthday_user.name)
    println(birthday_user.age)

    // 11. 记录扩展与类型推断
    val config = (host: "localhost", port: 8080)
    val prod_config = (...config, host: "prod.example.com")
    println(prod_config.host)
    println(prod_config.port)

    println("Phase 3: All tests passed!")
}
