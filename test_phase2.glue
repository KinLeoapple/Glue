// ============================================================

val makeCircle = Circle
val c2 = makeCircle(7.0)
println(c2)

// ============================================================
// 23. ADT — 表达式树
// ============================================================

type Expr =
    | Num(i32)
    | Add(Expr, Expr)
    | Mul(Expr, Expr)

fun eval(e: Expr): i32 {
    match e {
        Num(n) => n
        Add(left, right) => eval(left) + eval(right)
        Mul(left, right) => eval(left) * eval(right)
    }
}

// (1 + 2) * 3 = 9
val expr = Mul(Add(Num(1), Num(2)), Num(3))
println(eval(expr))

// 1 + (2 * 3) = 7
val expr2 = Add(Num(1), Mul(Num(2), Num(3)))
println(eval(expr2))

// ============================================================
// 24. ADT — Nullable 与 ADT 交互
// ============================================================

fun firstOf(l: List): i32? {
    match l {
        Nil => null
        Cons(head, _) => head
    }
}

println(firstOf(Nil))
println(firstOf(Cons(99, Nil)))

// ============================================================
// 25. ADT — 模式匹配穷举（_ 兜底）
// ============================================================

type Color =
    | Red
    | Green
    | Blue
    | Yellow

fun isPrimary(c: Color): bool {
    match c {
        Red | Green | Blue => true
        _ => false
    }
}

println(isPrimary(Red))
println(isPrimary(Yellow))

// ============================================================
// 26. Trait — 多方法 Trait
// ============================================================

trait Numeric {
    fun add(a, b)
    fun zero()
}

impl Numeric<i32> {
    fun add(a, b): i32 {
        a + b
    }
    fun zero(): i32 {
        0
    }
}

println(add(10, 20))
println(zero())

// ============================================================
// 27. ADT — 构造器嵌套匹配
// ============================================================

fun deepMatch(l: List): str {
    match l {
        Nil => "empty"
        Cons(x, Nil) => "one: " + str(x)
        Cons(x, Cons(y, Nil)) => "two: " + str(x) + ", " + str(y)
        _ => "many"
    }
}

println(deepMatch(Nil))
println(deepMatch(Cons(1, Nil)))
println(deepMatch(Cons(1, Cons(2, Nil))))
println(deepMatch(Cons(1, Cons(2, Cons(3, Nil)))))

// ============================================================
// 28. 综合测试 — 二叉树
// ============================================================

type Tree =
    | Leaf
    | Node(i32, Tree, Tree)

fun treeSize(t: Tree): i32 {
    match t {
        Leaf => 0
        Node(_, left, right) => 1 + treeSize(left) + treeSize(right)
    }
}

fun treeDepth(t: Tree): i32 {
    match t {
        Leaf => 0
        Node(_, left, right) => {
            val ld = treeDepth(left)
            val rd = treeDepth(right)
            if (ld > rd) { ld + 1 } else { rd + 1 }
        }
    }
}

//       5
//      / \
//     3   8
//    / \
//   1   4
val tree = Node(5, Node(3, Node(1, Leaf, Leaf), Node(4, Leaf, Leaf)), Node(8, Leaf, Leaf))

println(treeSize(tree))
println(treeDepth(tree))

fun treeSum(t: Tree): i32 {
    match t {
        Leaf => 0
        Node(v, left, right) => v + treeSum(left) + treeSum(right)
    }
}

println(treeSum(tree))

