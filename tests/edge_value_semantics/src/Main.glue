// 统一值语义回归：默认深拷贝，&T / *T 显式引用才共享

type Pair = Pair(a: i32, b: i32)

fun takesRec(p: (x: i32, y: i32)): i32 { p.x + p.y }

fun modifyRec(p: (x: i32, y: i32)) { p.x = 999 }

fun makeRec(): (x: i32, y: i32) {
    val inner = (x: 5i32, y: 6i32)
    inner
}

fun main() {
    // ---- 记录：val 别名 + var 改字段，原值不变 ----
    val a = (x: 1i32, y: 2i32)
    var b = a
    b.x = 99
    println(a.x)        // 1 (未被串改)
    println(b.x)        // 99

    // ---- 数组：别名 + 改元素，原数组不变 ----
    var arr = [1, 2, 3]
    var c = arr
    c[0] = 99
    println(arr[0])     // 1
    println(c[0])       // 99
    println(arr[1])     // 2

    // ---- 自身改字段正常 ----
    var r = (x: 5i32, y: 6i32)
    r.x = 50
    println(r.x)        // 50
    println(r.y)        // 6 (其它字段不变)

    // ---- 记录传参：函数内不改，外部原样 ----
    val pt = (x: 3i32, y: 4i32, z: 9i32)
    println(takesRec((x: pt.x, y: pt.y)))   // 7
    println(pt.x)           // 3

    // ---- 函数参数深拷贝：函数内修改不影响调用者 ----
    val arg = (x: 1i32, y: 2i32)
    modifyRec(arg)
    println(arg.x)          // 1

    // ---- 函数返回值深拷贝：多次调用结果独立 ----
    val r1 = makeRec()
    var r2 = makeRec()
    r2.x = 100
    println(r1.x)           // 5
    println(r2.x)           // 100

    // ---- &T 参数仍保持引用语义 ----
    fun modifyRef(p: &(x: i32, y: i32)) { p.x = 888 }
    var target = (x: 1i32, y: 2i32)
    modifyRef(&target)
    println(target.x)       // 888

    // ---- 多层别名链 ----
    val base = (k: 1i32)
    val x1 = base
    val x2 = x1
    var x3 = x2
    x3.k = 100
    println(base.k)     // 1
    println(x1.k)       // 1
    println(x2.k)       // 1
    println(x3.k)       // 100

    // ---- 数组里的记录元素（嵌套共享）----
    val rec = (n: 7i32)
    var lst = [rec, rec]
    lst[0] = (n: 70i32)
    println(rec.n)      // 7 (原记录不变)

    // ---- 记录更新 spread 不影响源 ----
    val src = (p: 1i32, q: 2i32, s: 3i32)
    val upd = (...src, q: 20i32)
    println(src.q)      // 2
    println(upd.q)      // 20
    println(upd.p)      // 1

    println("edge_value_semantics: All tests passed!")
}
