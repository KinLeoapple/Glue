type ParseError = Error("parse error")

fun parseOrThrow(s: str): Throw<i32, Error> {
    if (s == "valid") { Ok(42) }
    else if (s == "parse_fail") { throw ParseError("invalid syntax") }
    else { throw Error("unknown error") }
}

val pr1 = match parseOrThrow("valid") {
    Ok(v) => v
    Error(e) => -1
}
println(pr1)

val pr2 = match parseOrThrow("parse_fail") {
    Ok(v) => v
    Error(e) => -2
}
println(pr2)

val pr3 = match parseOrThrow("other") {
    Ok(v) => v
    Error(e) => -3
}
println(pr3)

