// 62. 多种 match 模式
// ============================================================

// 字面量模式
fun classify(n: i32): str {
    match n {
        0 => "zero"
        1 => "one"
        _ => "other"
    }
}
println(classify(0))
println(classify(1))
println(classify(42))

// 布尔模式
fun boolMatch(b: bool): str {
    match b {
        true => "yes"
        false => "no"
    }
}
println(boolMatch(true))
println(boolMatch(false))

