println(arr_chain.len())

// ============================================================
// 129. Nullable — 非空断言在非空值上
// ============================================================
val nn: i32? = 99
println(nn!)
println(nn ?? 0)

// ============================================================
// 130. loop — loop 带累加
// ============================================================
var loop_acc: i32 = 1
var loop_i: i32 = 1
loop {
    loop_acc = loop_acc * loop_i
    loop_i = loop_i + 1
    if (loop_i > 6) { break }
}
println(loop_acc)

}

fun test14(): () {
// ============================================================
// 131. while — 倒计时
// ============================================================
var countdown_val = 5
var countdown_result = ""
while countdown_val > 0 {
    countdown_result = countdown_result + str(countdown_val)
    countdown_val = countdown_val - 1
}
println(countdown_result)

// ============================================================
// 132. for — 嵌套 for 循环
// ============================================================
var nested_sum: i32 = 0
for i in 1..=3 {
    for j in 1..=3 {
        nested_sum = nested_sum + i * j
    }
}
println(nested_sum)

// ============================================================
// 133. match — match 表达式赋值
// ============================================================
val match_val = match 3 {
    1 => "one"
    2 => "two"
    3 => "three"
    _ => "other"
}
println(match_val)

// ============================================================
// 134. 函数 — 函数作为参数传递给高阶函数
// ============================================================
println(applyTwice(fun(x) { x + 1 }, 5))
println(applyTwice(fun(x) { x * 2 }, 3))

// ============================================================
// 135. Newtype — newtype 内部值提取
// ============================================================
val g1 = Grade(85)
val g2 = Grade(60)
println(extractGrade(g1))
println(extractGrade(g2))

// ============================================================
// 136. 字符串 — 字符串比较运算
// ============================================================
println("abc" == "abc")
println("abc" != "def")
println("apple" < "banana")

// ============================================================
// 137. 数组 — 数组元素求和与查找
// ============================================================
val search_arr = [5, 10, 15, 20, 25]
var search_sum: i32 = 0
for v in search_arr {
    search_sum = search_sum + v
}
println(search_sum)
println(search_arr.contains(15))
println(search_arr.contains(99))

// ============================================================
// 138. Nullable — 三元替代（if-else 表达式）
// ============================================================
println(clamp(-5, 0, 10))
println(clamp(5, 0, 10))
println(clamp(15, 0, 10))

// ============================================================
// 139. UTF-8 字符串 — len() 返回 Unicode 标量值
// ============================================================
val cn = "你好"
println(cn.len())

val mixed = "a你好b"
println(mixed.len())

// ============================================================
// 140. char → str 转换
// ============================================================
println(str('A'))
println(str('Z'))

// ============================================================
// 141. 守卫条件与或模式组合
// ============================================================
println(classifyNum2(0))
println(classifyNum2(2))
println(classifyNum2(-5))
println(classifyNum2(100))

// ============================================================
// 142. 记录模式解构
// ============================================================
println(quadrant(Pt2(0, 0)))
println(quadrant(Pt2(1, 1)))
println(quadrant(Pt2(-1, 1)))
println(quadrant(Pt2(-1, -1)))
println(quadrant(Pt2(1, -1)))
println(quadrant(Pt2(0, 5)))

}

fun test15(): () {
// ============================================================
// 143. Nullable — if-else 返回 Nullable
// ============================================================
println(safeDiv2(10, 2) ?? -1)
println(safeDiv2(10, 0) ?? -1)

// ============================================================
// 144. Throw — 链式 ? 传播更多场景
// ============================================================
val pad1 = match parseAndDouble("valid") {
    Ok(v) => v
    Error(e) => -1
}
println(pad1)

val pad2 = match parseAndDouble("invalid") {
    Ok(v) => v
    Error(e) => -1
}
println(pad2)

// ============================================================
// 145. 闭包 — 闭包作为参数传递给高阶函数
// ============================================================
println(applyTwice2(fun(x) { x + 1 }, 5))
println(applyTwice2(fun(x) { x * 2 }, 3))

// ============================================================
// 146. 数组 — 数组操作综合
// ============================================================
var arr_ops = [1, 2, 3]
arr_ops = arr_ops.push(4)
arr_ops = arr_ops.push(5)
println(arr_ops.len())
println(arr_ops.contains(3))
println(arr_ops.contains(99))

val arr_drop = arr_ops.drop_last()
println(arr_drop.len())

// ============================================================
// 147. 嵌套记录 — 更多场景
// ============================================================
val s1 = Shape2(Rect(3.0, 4.0), "rectangle")
println(s1.rect.w)
println(s1.rect.h)
println(s1.label)

// ============================================================
// 148. match — 守卫条件
// ============================================================
println(fizzbuzz(15))
println(fizzbuzz(9))
println(fizzbuzz(10))
println(fizzbuzz(7))

// ============================================================
// 149. 字符串 — 更多插值
// ============================================================
val px2 = 3
val py2 = 4
println("point: ({px2}, {py2})")
println("distance squared: {px2 * px2 + py2 * py2}")

// ============================================================
// 150. 递归 — 更复杂的递归
// ============================================================
println(gcd(48, 18))
println(gcd(100, 75))

// ============================================================
// 151. 动态数组 — map/filter 模式
// ============================================================
val mapped = mapArray([1, 2, 3, 4, 5], fun(x) { x * x })
println(mapped)

val evens = filterArray([1, 2, 3, 4, 5, 6], fun(x) { x % 2 == 0 })
println(evens)

// ============================================================
// 152. while — 欧几里得算法迭代版
// ============================================================
println(gcdIter(48, 18))
println(gcdIter(100, 75))

// ============================================================
// 153. Type Alias — 函数中使用
// ============================================================
println(passThreshold(85))
println(passThreshold(30))

// ============================================================
// 154. 闭包 — applyTwice3
// ============================================================
println(applyTwice3(fun(x) { x + 1 }, 5))
println(applyTwice3(fun(x) { x * 2 }, 3))

}

