type GList<T> =
    | GNil
    | GCons(T, GList<T>)

val glist1 = GCons(10, GCons(20, GCons(30, GNil)))
val glist2 = GCons("a", GCons("b", GCons("c", GNil)))

fun glistLen(l: GList<i32>): i32 {
    match l {
        GNil => 0
        GCons(_, tail) => 1 + glistLen(tail)
    }
}
println(glistLen(glist1))
println(glistLen(GNil))

