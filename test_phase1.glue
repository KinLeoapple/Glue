println(empty_arr.first())
println(empty_arr.last())

// drop_last
val dropped = dyn_arr.drop_last()
println(dropped)

// ============================================================
// 53. Nullable 与泛型交互 — 更多场景
// ============================================================

// Nullable 作为函数返回值
fun findUser(id: i32): str? {
    if (id == 1) { "Alice" } else { null }
}

val user1 = findUser(1)
val user2 = findUser(2)
println(user1 ?? "unknown")
println(user2 ?? "unknown")

// Nullable 嵌套在 Throw 中
fun findOrError(id: i32): Throw<str?, Error> {
    if (id < 0) {
        throw Error("invalid id")
    }
    if (id == 0) {
        Ok(null)
    } else {
        Ok(findUser(id))
    }
}

val r3 = match findOrError(-1) {
    Ok(v) => v ?? "null value"
    Error(e) => "error: " + e.message
}
println(r3)

val r4 = match findOrError(0) {
    Ok(v) => v ?? "null value"
    Error(e) => "error"
}
println(r4)

val r5 = match findOrError(1) {
    Ok(v) => v ?? "null value"
    Error(e) => "error"
}
println(r5)

