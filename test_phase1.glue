println(i8_val)
println(u8_val)
println(i64_val)

// ============================================================
// 2. Nullable
// ============================================================
val x: i32? = null
val y = x ?? 99
println(y)

val z: i32? = 10
val w = z ?? 99
println(w)

// 非空断言 !
val nz: i32? = 42
val nv = nz!
println(nv)

// 安全访问 ?.
val nullable_point: (x: i32, y: i32)? = null
val safe_x = nullable_point?.x
println(safe_x)

// ============================================================
// 3. Ok/Error 和 Throw
// ============================================================
val result = Ok(42)
println(result)

val err = Error("something failed")
println(err)

// throw 语句
fun mightFail(x: i32): Throw<i32, Error> {
    if (x < 0) {
        throw Error("negative value")
    }
    Ok(x * 2)
}
println(mightFail(5))

// ============================================================
// 4. match Ok/Error
// ============================================================
val r = match Ok(100) {
    Ok(v) => v + 1
    Error(e) => 0
}
println(r)

