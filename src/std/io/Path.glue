// Path.glue — 跨平台路径抽象（纯 Glue 实现，无 syscall 依赖）
//
// 设计文档 §4.4：Path newtype + 路径操作
// Path 内部存储 segments（已规范化的非空段列表）+ is_absolute 标志
//
// Phase 2 重构：完全去除 __path_* syscall 依赖
// - 分隔符规范化：'\' → '/'，去除冗余 '.'
// - 路径切分：按 '/' 拆分并过滤空段与当前目录标记
// - 绝对性：检测首字符是否为 '/'
// - 路径拼接：segments 数组拼接 + 绝对性继承

pub type Path = Path(segments: str[], is_absolute: bool)

// ─── 辅助函数 ─────────────────────────────────────────────────────

// 路径分隔符规范化：'\' → '/'
// 不调用 syscall，纯字符串扫描替换
pub fun normalize_seps(s: str): str {
    var bytes = s.bytes()
    var out: u8[] = []
    for b in bytes {
        if b == cast('\\').to(u8) {
            out = out ++ [cast('/').to(u8)]
        } else {
            out = out ++ [b]
        }
    }
    cast(out).to(str)
}

// 按分隔符切分字符串，过滤空段和 "."（当前目录）
// 返回非空、非 "." 的段列表
pub fun split_segments(s: str): str[] {
    var result: str[] = []
    var start: usize = 0
    var i: usize = 0
    while i < s.len() {
        val c = s[i]
        if c == '/' || c == '\\' {
            if i > start {
                val seg = s[start..i]
                if seg != "." && seg != "" {
                    result = result ++ [seg]
                }
            }
            start = i + 1
        }
        i = i + 1
    }
    // 处理末尾段
    if start < s.len() {
        val seg = s[start..s.len()]
        if seg != "." && seg != "" {
            result = result ++ [seg]
        }
    }
    result
}

// 拼接路径段为字符串
// abs=true 时前缀 '/'，否则无前缀
pub fun join_segments_to_str(segs: str[], abs: bool): str {
    var result: str = ""
    if abs {
        result = "/"
    }
    var first = true
    for seg in segs {
        if !first {
            result = result + "/"
        }
        result = result + seg
        first = false
    }
    result
}

// 从字符串查找字符的最后位置（字符索引，Unicode 标量值）
// 未找到返回 -1
pub fun last_index_of(s: str, ch: char): i64 {
    var i: usize = s.len()
    while i > 0 {
        i = i - 1
        if s[i] == ch {
            return cast(i).to(i64)
        }
    }
    return -1
}

// ─── 构造 ──────────────────────────────────────────────────────────

// 从字符串构造 Path：规范化分隔符 → 切分 → 记录绝对性
pub fun path_from(s: str): Path {
    val normalized = normalize_seps(s)
    val parts = split_segments(normalized)
    val abs = normalized.len() > 0 && normalized[0] == '/'
    Path(parts, abs)
}

// ─── 转换 ──────────────────────────────────────────────────────────

pub fun to_str(self: Path): str {
    join_segments_to_str(self.segments, self.is_absolute)
}

// ─── 拼接 ──────────────────────────────────────────────────────────

pub fun join(self: Path, other: Path): Path {
    Path(self.segments ++ other.segments, self.is_absolute)
}

pub fun join_str(self: Path, other: str): Path {
    self.join(path_from(other))
}

// ─── 路径分解 ──────────────────────────────────────────────────────

// 父目录：去掉最后一段。根路径或空 segments 返回 null
pub fun parent(self: Path): Path? {
    val len = self.segments.len()
    if len == 0 {
        null
    } else {
        val parent_segs = self.segments[0..len - 1]
        Path(parent_segs, self.is_absolute)
    }
}

// 末尾段（文件名）。空 segments 返回 null
pub fun filename(self: Path): str? {
    val len = self.segments.len()
    if len == 0 {
        null
    } else {
        self.segments[len - 1]
    }
}

// 扩展名（不含点）。无点或点在首位返回 null
pub fun extension(self: Path): str? {
    val fname = self.filename()
    match fname {
        null => null,
        name => {
            val dot = std.io.Path.last_index_of(name, '.')
            if dot <= 0 {
                null
            } else {
                val dot_idx = cast(dot).to(usize)
                name[dot_idx + 1..name.len()]
            }
        },
    }
}

// 文件名（去扩展名）。无点返回完整 filename
pub fun file_stem(self: Path): str? {
    match self.filename() {
        null => null,
        name => {
            val dot = last_index_of(name, '.')
            if dot <= 0 {
                name
            } else {
                val dot_idx = cast(dot).to(usize)
                name[0..dot_idx]
            }
        },
    }
}

// ─── 查询 ──────────────────────────────────────────────────────────

pub fun is_absolute_path(self: Path): bool { self.is_absolute }

pub fun is_relative_path(self: Path): bool { !self.is_absolute }
