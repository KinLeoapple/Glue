// Phase 5: HKT (Higher-Kinded Types) 测试
// 文档 §2.11: Kind 系统、Functor/Monad、@ 上下文表达式

type List<T> =
    | Nil
    | Cons(T, List<T>)

fun concat(a: List<i32>, b: List<i32>) : List<i32> {
    match a {
        Nil => b,
        Cons(h, t) => Cons(h, concat(t, b)),
    }
}

fun show(l: List<i32>) : str {
    match l {
        Nil => "nil",
        Cons(h, t) => str(h) + "," + show(t),
    }
}

// 文档 §2.11.1: Functor/Monad 用 Kind 注解 F : * -> *
// Functor 用文档原样的高阶签名 map<T,U>(ft: F<T>, f: T -> U) : F<U>
trait Functor<F : * -> *> {
    fun map<T, U>(ft: F<T>, f: T -> U) : F<U>
}

trait Monad<F : * -> *> {
    fun pure(value: i32) : List<i32>
    fun bind(list: List<i32>, f: i32 -> List<i32>) : List<i32>
}

impl Functor<List> {
    fun map(ft, f) {
        match ft {
            Nil => Nil,
            Cons(h, t) => Cons(f(h), map(t, f)),
        }
    }
}

impl Monad<List> {
    fun pure(value) { Cons(value, Nil) }
    fun bind(list, f) {
        match list {
            Nil => Nil,
            Cons(h, t) => concat(f(h), bind(t, f)),
        }
    }
}

// 多 Monad：同一程序里再定义另一个 Monad 实例。
// bind/pure 同名，但按接收者运行时类型分派到正确的 impl（文档 §2.7.1）。
type Box<T> = Box(T)

impl Monad<Box> {
    fun pure(value) { Box(value) }
    fun bind(b, f) {
        match b {
            Box(v) => f(v),
        }
    }
}

fun unbox(b: Box<i32>) : i32 {
    match b {
        Box(v) => v,
    }
}

fun main() {
    // 文档 §2.11.1: Functor map — 对容器内每个元素应用函数
    val nums = Cons(1, Cons(2, Cons(3, Nil)))
    val tripled = map(nums, fun(x) { x * 3 })
    println(show(tripled))   // 3,6,9,nil

    // 文档 §2.11.2: @ 上下文表达式（do-notation）
    val r = @List {
        x <- Cons(1, Cons(2, Cons(3, Nil)))
        y <- Cons(10, Cons(20, Nil))
        x + y
    }
    // x in {1,2,3}, y in {10,20} => 11,21,12,22,13,23
    println(show(r))

    // 单绑定
    val s = @List {
        n <- Cons(5, Cons(6, Nil))
        n * 2
    }
    println(show(s))

    // 多 Monad：同一作用域用 @Box，分派到 Box 的 bind/pure（非 List 的）
    val bx = @Box {
        a <- Box(5)
        b <- Box(100)
        a + b
    }
    println(unbox(bx))   // 105

    // 紧接着再用 @List，确认两个 Monad 互不干扰
    val r2 = @List {
        z <- Cons(7, Cons(8, Nil))
        z + 1
    }
    println(show(r2))    // 8,9,nil

    println("Phase 5: All tests passed!")
}
