// Phase 4 并发原语功能验证
// 严格按照语言设计规范 Phase 4 表格：
//   Atomic<T>、Async<T>、Channel、select、Per-Heap GC

// ============================================================
// 1. async 函数 + await 基本功能
// ============================================================

// async 函数：调用返回 Async<T>，需 .await() 取结果
async fun make42(): i64 { 42 }

// async 函数深拷贝捕获：内部修改不影响外部
async fun incrCount(c: i64): i64 { c + 1 }

// async 函数捕获 Atomic：共享底层内存
async fun incrAtomic(counter: Atomic<i64>): Unit { counter = counter + 1 }

// async 函数链式调用
async fun mul42(): i64 { 7 * 6 }

// async 函数：status 查询
async fun make99(): i64 { 99 }

fun main() {
    // 1. async + await：async 函数调用返回 Async<T>，await 阻塞等待结果
    val s1 = make42()
    val r1 = s1.await()
    println(r1)

    // 2. async 深拷贝隔离性验证
    // async 函数实参深拷贝，内部修改不影响外部
    var count = 0
    val s2 = incrCount(count)
    val r2 = s2.await()
    println(r2)
    println(count)

    // 3. Atomic<T> 跨 async 共享
    // Atomic 在实参传递时浅拷贝，共享底层内存
    var counter = atomic 0i64
    val s3 = incrAtomic(counter)
    s3.await()
    println(counter)

    // 4. Channel 发送/接收
    val ch = channel(10)
    ch.send(100)
    ch.send(200)
    val v1 = ch.recv()
    val v2 = ch.recv()
    println(v1)
    println(v2)

    // 5. Channel 关闭语义（文档 D57: 仅 Sender 可关闭）
    val ch2 = channel(10)
    ch2.send(1)
    ch2.send(2)
    ch2.sender.close()
    // 关闭后缓冲数据仍可读取
    val c1 = ch2.recv()
    val c2 = ch2.recv()
    println(c1)
    println(c2)
    // 缓冲耗尽且已关闭，recv 返回 null
    val c3 = ch2.recv()
    println(c3)

    // 6. Channel 方向类型（sender / receiver）
    val ch3 = channel(10)
    val sender = ch3.sender
    val receiver = ch3.receiver
    sender.send(42)
    val rv = receiver.recv()
    println(rv)
    sender.close()

    // 7. AsyncStatus 查询
    val s4 = make99()
    val status_before = s4.status()
    println(status_before)
    val r4 = s4.await()
    val status_after = s4.status()
    println(status_after)
    println(r4)

    // 8. Atomic cas/swap 显式操作
    var atm = atomic 10
    val swapped = atm.swap(20)
    println(swapped)
    println(atm)

    val cas_ok = atm.cas(20, 30)
    println(cas_ok)

    val cas_fail = atm.cas(99, 40)
    println(cas_fail)

    println(atm)

    // 9. select 多路复用（带缓冲的 channel 可立即就绪）
    val ch_a = channel(10)
    val ch_b = channel(10)
    ch_a.send(111)
    select {
        ch_a.recv() => println("from ch_a"),
        ch_b.recv() => println("from ch_b"),
    }

    // 10. async 链式调用
    val r5 = mul42().await()
    println(r5)

    println("Phase 4: All tests passed!")
}
