// ============================================================
// 11. Trait — 定义
// ============================================================

trait Describable {
    fun describe(self): str
}

// ============================================================
// 12. Trait — impl 实现（语法：impl TraitName<Type> { methods }）
// ============================================================

impl Describable<Ordering> {
    fun describe(self): str {
        match self {
            Lt => "less than"
            Eq => "equal"
            Gt => "greater than"
        }
    }
}

// ============================================================
// 13. Trait — 带默认实现的 Trait
// ============================================================

trait Printable {
    fun format(self): str
    fun print(self): str {
        "<" + self.format() + ">"
    }
}

// ============================================================
// 14. Trait — Comparable
// ============================================================

trait Comparable {
    fun compare(a, b): Ordering
}

impl Comparable<i32> {
    fun compare(a, b): Ordering {
        if (a < b) { Lt } else if (a == b) { Eq } else { Gt }
    }
}

// 使用 impl 中注册的方法
val cmp1 = compare(1, 2)
val cmp2 = compare(5, 5)
val cmp3 = compare(10, 3)
println(cmp1)
println(cmp2)
println(cmp3)

// ============================================================
// 15. Trait Bound — with 语法
// ============================================================

fun myMax(a: i32, b: i32): i32 with Comparable {
    match compare(a, b) {
        Lt => b
        Eq => a
        Gt => a
    }
}

println(myMax(3, 7))
println(myMax(10, 2))
println(myMax(5, 5))

