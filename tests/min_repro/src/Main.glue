// 回归测试：验证 async 函数的 Atomic 参数共享引用
// 修复前：op_get_local 透明 load 把 atomic 解包成 int，async 函数内 fetchAdd 作用在副本上
// 修复后：op_get_local_raw 保留 atomic 引用，async 函数内 fetchAdd 修改共享状态
async fun testIncr(a: Atomic<i32>): Unit { a += 1 }

fun main() {
    var counter = atomic 0
    val s = testIncr(counter)
    s.await()
    val old = counter.swap(0)
    println(old)  // 期望 1：async 函数通过共享 atomic 引用修改了 counter
    println(counter)  // 期望 0：swap(0) 重置

    println("min_repro: done")
}
