// ============================================================
// 27. ? 传播
// ============================================================
fun maybeNull(): i32? {
    null
}

// ? 传播 null：maybeNull()? 返回 null，函数提前退出
fun useNullable(): i32? {
    val v = maybeNull()?
    v + 1
}
val use_result = useNullable()
println(use_result)

