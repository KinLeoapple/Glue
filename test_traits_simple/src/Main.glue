// 测试：单个 trait 不用括号

trait Greet {
    fun greet_name(self): str
}

type Color: Greet = | Red | Green | Blue {
    fun greet_name(self): str {
        match self {
            Red => "red"
            Green => "green"
            Blue => "blue"
        }
    }
}

fun main() {
    val x = Red
    println(x.greet_name())
}
