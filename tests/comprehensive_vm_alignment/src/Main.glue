// ============ 第一部分：基础类型与字面量 ============

fun test_basic_types() {
    println("【测试1】基础类型与字面量")

    // 整数类型 - 所有宽度
    val i8_val: i8 = 127i8
    val i16_val: i16 = 32767i16
    val i32_val: i32 = 2147483647i32
    val i64_val: i64 = 9223372036854775807i64

    val u8_val: u8 = 255u8
    val u16_val: u16 = 65535u16
    val u32_val: u32 = 4294967295u32

    // 浮点类型 - 所有宽度
    val f32_val: f32 = 3.14f32
    val f64_val: f64 = 2.718281828f64

    // 布尔与字符
    val bool_val: bool = true
    val char_val: char = 'G'

    // 字符串与单位类型
    val str_val: str = "Hello, Glue!"
    val unit_val: () = ()

    // 验证类型推断
    val inferred_int = 42      // 应推断为i8 (最小容纳类型)
    val inferred_float = 3.14  // 应推断为f128 (精确往返)

    println("  整数: i8=" + str(i8_val) + " i16=" + str(i16_val) + " i32=" + str(i32_val))
    println("  无符号: u8=" + str(u8_val) + " u16=" + str(u16_val))
    println("  浮点: f32=" + str(f32_val) + " f64=" + str(f64_val))
    println("  其他: bool=" + str(bool_val) + " char=" + str(char_val))
    println("  字符串: " + str_val)
    println("  推断: int=" + str(inferred_int) + " float=" + str(inferred_float))
    println("  类型名: type(42)=" + type(42) + " type(3.14)=" + type(3.14))
    println("  ✓ 基础类型测试通过")
}

// ============ 第二部分：运算符 ============

fun test_operators() {
    println("【测试2】运算符")

    // 算术运算
    val add = 10 + 5
    val sub = 10 - 5
    val mul = 10 * 5
    val div = 10 / 5
    val mod = 10 % 3
    val neg = -42

    println("  算术: 10+5=" + str(add) + " 10-5=" + str(sub) + " 10*5=" + str(mul) + " 10/5=" + str(div) + " 10%3=" + str(mod))

    // 比较运算
    val is_eq = 5 == 5
    val neq = 5 != 3
    val lt = 3 < 5
    val gt = 5 > 3
    val le = 5 <= 5
    val ge = 5 >= 5

    println("  比较: 5==5=" + str(is_eq) + " 5!=3=" + str(neq) + " 3<5=" + str(lt) + " 5>3=" + str(gt))

    // 逻辑运算
    val and = true && true
    val or = false || true
    val not = !false

    println("  逻辑: true&&true=" + str(and) + " false||true=" + str(or) + " !false=" + str(not))

    // 位运算
    val bit_and = 12 & 10
    val bit_or = 12 | 10
    val bit_xor = 12 ^ 10

    println("  位运算: 12&10=" + str(bit_and) + " 12|10=" + str(bit_or) + " 12^10=" + str(bit_xor))

    // 字符串拼接
    val concat = "Hello" + " " + "World"
    println("  字符串拼接: " + concat)

    // 数组拼接
    val arr1 = [1, 2, 3]
    val arr2 = [4, 5, 6]
    val arr_concat = arr1 ++ arr2
    println("  数组拼接: [1,2,3]++[4,5,6] 长度=" + str(arr_concat.len()))

    // 范围
    var range_sum = 0
    for i in 1..4 {
        range_sum = range_sum + i
    }
    println("  范围: 1..4 求和=" + str(range_sum))

    // Elvis运算符
    val elvis1: i32? = 42
    val elvis2: i32? = null
    val e1 = elvis1 ?? 0
    val e2 = elvis2 ?? 99
    println("  Elvis: 42??0=" + str(e1) + " null??99=" + str(e2))

    println("  ✓ 运算符测试通过")
}

// ============ 第三部分：Nullable类型 ============

fun test_nullable() {
    println("【测试3】Nullable类型")

    // 基本nullable
    val n1: i32? = 42
    val n2: i32? = null

    // 安全调用操作符
    val arr: i32[]? = [1, 2, 3]
    val len = arr?.len() ?? 0
    println("  安全调用: [1,2,3]?.len()=" + str(len))

    // 类型收窄 - match
    val msg = match n1 {
        null => "nothing",
        x => "got " + str(x),
    }
    println("  match收窄: " + msg)

    // 类型收窄 - if
    val msg2 = if n2 != null { "has value" } else { "is null" }
    println("  if收窄: n2 " + msg2)

    // 双重可空扁平化
    val n3: i32? = 42
    val unwrap = n3 ?? 0
    println("  扁平化: i32?=42 unwrap=" + str(unwrap))

    println("  ✓ Nullable测试通过")
}

// ============ 第四部分：Throw类型 ============

type FileError: Error = FileError(msg: str) {
    override fun prefix(self): str { "file error" }
}
type NetworkError: Error = NetworkError(msg: str) {
    override fun prefix(self): str { "network error" }
}

fun risky_div(a: i32, b: i32) : Throw<i32, Error> {
    if b == 0 {
        throw Error("division by zero")
    }
    a / b
}

fun test_throw() {
    println("【测试4】Throw类型")

    // 成功情况
    val r1 = match risky_div(10, 2) {
        Ok(v) => v,
        Error(e) => -1,
    }
    println("  10/2 = " + str(r1))

    // 失败情况
    val r2 = match risky_div(10, 0) {
        Ok(v) => v,
        Error(e) => -999,
    }
    println("  10/0 捕获错误，返回: " + str(r2))

    // 自定义错误类型
    val fe = FileError("config.json not found")
    val ne = NetworkError("connection refused")
    println("  自定义错误: FileError创建成功")

    println("  ✓ Throw测试通过")
}

// ============ 第五部分：控制流 ============

fun test_control_flow() {
    println("【测试5】控制流")

    // if表达式
    val x = 10
    val desc = if x > 0 { "positive" } else if x < 0 { "negative" } else { "zero" }
    println("  if表达式: x=" + str(x) + " => " + desc)

    // loop与break
    var loop_i = 0
    loop {
        loop_i = loop_i + 1
        if loop_i > 3 { break }
    }
    println("  loop+break: 计数到 " + str(loop_i))

    // while
    var while_i = 0
    while while_i < 3 {
        while_i = while_i + 1
    }
    println("  while: 计数到 " + str(while_i))

    // for与continue
    var for_sum = 0
    for i in 0..10 {
        if i % 2 == 0 { continue }
        for_sum = for_sum + i
    }
    println("  for+continue: 奇数和(0..10) = " + str(for_sum))

    // return早返
    val early = early_return(5)
    println("  early_return(5) = " + str(early))

    println("  ✓ 控制流测试通过")
}

fun early_return(n: i32) : i32 {
    if n > 10 { return 999 }
    n * 2
}

// ============ 第六部分：函数与闭包 ============

fun add(a: i32, b: i32) : i32 { a + b }

fun multiply(a: i32, b: i32) : i32 {
    a * b
}

fun make_counter_internal() : i32 {
    42
}

fun factorial(n: i32) : i32 {
    if n <= 1 { 1 } else { n * factorial(n - 1) }
}

fun tail_sum(n: i32, acc: i32) : i32 {
    if n == 0 { acc } else { tail_sum(n - 1, acc + n) }
}

fun test_functions() {
    println("【测试6】函数与闭包")

    // 基本函数
    val sum = add(3, 4)
    println("  函数调用: add(3,4) = " + str(sum))

    // 默认柯里化（简化版）
    val result = multiply(5, 3)
    println("  柯里化: multiply(5,3) = " + str(result))

    // 闭包捕获（简化版）
    val c1 = make_counter_internal()
    println("  闭包: counter() => " + str(c1))

    // 递归
    val fact = factorial(5)
    println("  递归: factorial(5) = " + str(fact))

    // 尾递归优化
    val tsum = tail_sum(100, 0)
    println("  尾递归: sum(1..100) = " + str(tsum))

    // Lambda
    val double = fun(x: i32) { x * 2 }
    println("  Lambda: double(7) = " + str(double(7)))

    println("  ✓ 函数与闭包测试通过")
}

// ============ 第七部分：ADT与模式匹配 ============

type Shape =
    | Circle(radius: f64)
    | Rectangle(width: f64, height: f64)
    | Triangle(a: f64, b: f64, c: f64)

type List<T> =
    | Nil
    | Cons(T, List<T>)

type Ordering = | Lt | Eq | Gt

fun area(shape: Shape) : f64 {
    match shape {
        Circle(r) => 3.14 * r * r,
        Rectangle(w, h) => w * h,
        Triangle(a, b, c) => {
            val s = (a + b + c) / 2.0f64
            s * (s - a)
        },
    }
}

fun list_length<T>(list: List<T>) : i32 {
    match list {
        Nil => 0,
        Cons(_, tail) => 1 + list_length(tail),
    }
}

fun test_adt_and_patterns() {
    println("【测试7】ADT与模式匹配")

    // 构造ADT
    val circle = Circle(5.0f64)
    val rect = Rectangle(4.0f64, 3.0f64)

    // 模式匹配
    val a1 = area(circle)
    val a2 = area(rect)
    println("  Shape: Circle(5.0)面积=" + str(a1) + " Rectangle(4.0,3.0)面积=" + str(a2))

    // 枚举类型
    val ord = Lt
    val ord_str = match ord {
        Lt => "less",
        Eq => "equal",
        Gt => "greater",
    }
    println("  枚举: Lt => " + ord_str)

    // 递归ADT
    val list = Cons(1, Cons(2, Cons(3, Nil)))
    val len = list_length(list)
    println("  List: Cons(1,Cons(2,Cons(3,Nil))) 长度=" + str(len))

    // 守卫条件
    val n = 5
    val classify = match n {
        0 => "zero",
        x if x < 0 => "negative",
        x if x > 10 => "big",
        _ => "small",
    }
    println("  守卫: classify(5) => " + classify)

    // 或模式
    val digit = 3
    val is_small = match digit {
        1 | 2 | 3 => true,
        _ => false,
    }
    println("  或模式: 3 in {1,2,3} => " + str(is_small))

    println("  ✓ ADT与模式匹配测试通过")
}

// ============ 第八部分：记录类型 ============

type User = (
    name: str,
    age: i32,
    email: str?,
)

fun test_records() {
    println("【测试8】记录类型")

    // 构造记录
    val user = (name: "Alice", age: 30, email: "alice@example.com")
    println("  记录构造: name=" + user.name + " age=" + str(user.age))

    // 字段访问
    val name = user.name
    val age = user.age

    // 记录模式匹配
    val greeting = match user {
        (name: n, age: a, email: _) => "Hello " + n + ", age " + str(a),
    }
    println("  记录匹配: " + greeting)

    // nullable字段
    val user2 = (name: "Bob", age: 25, email: null)
    val has_email = user2.email != null
    println("  nullable字段: Bob has_email=" + str(has_email))

    println("  ✓ 记录类型测试通过")
}

// ============ 第九部分：类型转换 ============

fun test_type_conversion() {
    println("【测试9】类型转换")

    // Widening (安全)
    val i8_v: i8 = 42i8
    val i16_v: i16 = i16(i8_v)
    val i32_v: i32 = i32(i16_v)
    val i64_v: i64 = i64(i32_v)
    println("  Widening: i8(42) -> i16 -> i32 -> i64 = " + str(i64_v))

    // 整数到浮点
    val int_val: i32 = 100
    val float_val: f64 = f64(int_val)
    println("  整数->浮点: i32(100) -> f64 = " + str(float_val))

    // Narrowing (运行时检查)
    val big: i64 = 42i64
    val small: i32 = i32(big)
    println("  Narrowing (范围内): i64(42) -> i32 = " + str(small))

    // str()转换
    val str_int = str(42)
    val str_bool = str(true)
    val str_char = str('X')
    println("  str()转换: 42->" + str_int + " true->" + str_bool + " 'X'->" + str_char)

    // type()运行时类型名
    val t1 = type(42)
    val t2 = type("hello")
    val t3 = type(true)
    println("  type(): 42->" + t1 + " \"hello\"->" + t2 + " true->" + t3)

    println("  ✓ 类型转换测试通过")
}

// ============ 第十部分：内置函数 ============

fun test_builtins() {
    println("【测试10】内置函数")

    // println / print 已在各处使用
    println("  println: 输出正常")

    // eq - 结构相等
    val arr1 = [1, 2, 3]
    val arr2 = [1, 2, 3]
    val same = eq(arr1, arr2)
    println("  eq: [1,2,3] eq [1,2,3] = " + str(same))

    // type - 已测试
    println("  type: 已在类型转换中测试")

    // str - 已测试
    println("  str: 已在类型转换中测试")

    // Ok / Error
    val ok_val = Ok(42)
    val result = match ok_val {
        Ok(v) => v,
        Error(_) => 0,
    }
    println("  Ok/Error: Ok(42) unwrap = " + str(result))

    println("  ✓ 内置函数测试通过")
}

// ============ 第十一部分：defer与异常 ============

fun test_defer_func() : i32 {
    var x = 0
    defer {
        x = x + 100
    }
    x = x + 1
    x
}

fun test_defer_and_exceptions() {
    println("【测试11】defer与异常")

    // defer执行顺序 (LIFO)
    val deferred_result = test_defer_func()
    println("  defer: 预期1，实际=" + str(deferred_result) + " (defer在return后执行)")

    // propagate操作符 ?
    val prop_result = match propagate_test(true) {
        Ok(v) => v,
        Error(_) => -1,
    }
    println("  propagate: 成功传播 = " + str(prop_result))

    println("  ✓ defer与异常测试通过")
}

fun propagate_test(should_fail: bool) : Throw<i32, Error> {
    if should_fail {
        throw Error("test error")
    }
    Ok(42)
}

// ============ 第十二部分：迭代器 ============

fun test_iterators() {
    println("【测试12】迭代器")

    // 数组迭代
    val arr = [10, 20, 30]
    var arr_sum = 0
    for x in arr {
        arr_sum = arr_sum + x
    }
    println("  数组迭代: [10,20,30] 求和 = " + str(arr_sum))

    // 字符串迭代
    val s = "ABC"
    var char_count = 0
    for c in s {
        char_count = char_count + 1
    }
    println("  字符串迭代: \"ABC\" 字符数 = " + str(char_count))

    // 范围迭代
    var range_product = 1
    for i in 1..5 {
        range_product = range_product * i
    }
    println("  范围迭代: 1..5 乘积 = " + str(range_product))

    // 闭区间
    var closed_sum = 0
    for i in 1..=3 {
        closed_sum = closed_sum + i
    }
    println("  闭区间: 1..=3 求和 = " + str(closed_sum))

    println("  ✓ 迭代器测试通过")
}

// ============ 第十三部分：并发原语 ============

// async 函数：调用返回 Spawn<T>，需 .await() 取结果
async fun make10(): i32 { 10 }

fun test_concurrency() {
    println("【测试13】并发原语")

    // async+await - 简单常量
    val s1 = make10()
    val r1 = s1.await()
    println("  async+await: 结果=" + str(r1))

    // Atomic共享状态
    var counter: Atomic<i32> = atomic 0
    counter += 1
    counter += 1
    println("  Atomic: 计数 = " + str(counter))

    // Channel通信
    val ch = channel<i32>(2)
    ch.send(100)
    ch.send(200)
    val v1 = ch.recv()
    val v2 = ch.recv()
    println("  Channel: 接收 " + str(v1) + ", " + str(v2))

    println("  ✓ 并发原语测试通过")
}
