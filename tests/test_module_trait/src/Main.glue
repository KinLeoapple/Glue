// Phase: 文件模块作为 Trait 值（结构化匹配）
// 文档 §2.7.5 名义化 vs 结构化匹配、§2.12.2 Trait 结构化子类型、§4.6.2 文件模块作为 Trait 值。
//
// 关键点：trait 名（KVStore，契约）与模块名（Store，实现目录）刻意取不同名字，
// 以体现「文件模块作为 Trait 值」靠的是结构化匹配（§2.12.2），二者无名义绑定——
// Store.Memory 模块并未 `impl KVStore`，只是结构上提供了 KVStore 要求的全部方法。
import Store

// KVStore trait：要求 put / get（Store.Memory 模块结构化满足之）。
trait KVStore {
    fun put(key: str, value: str) : Unit
    fun get(key: str) : str
}

// 一等 Trait 值作为运行时参数：vtable 分派到 Store.Memory 模块的函数。
fun run(s: KVStore) : Unit {
    s.put("hello", "world")
    println(s.get("hello"))
}

fun main() {
    // 文档 §4.6.2: 文件模块 Store.Memory 自动转换为 Trait 值传入。
    run(Store.Memory)

    // 限定访问：Store.Memory 取子模块值，直接调用其方法。
    Store.Memory.delete("hello")

    println("Module-as-Trait: All tests passed!")
}
