// ============================================================
// 41. 多层 ? 传播
// ============================================================

fun getFirst(): i32? { null }
fun getSecond(): i32? { 42 }

fun chain(): i32? {
    val a = getFirst()?
    val b = getSecond()?
    a + b
}
println(chain())

fun chain2(): i32? {
    val b = getSecond()?
    b + 1
}
println(chain2())

// ============================================================
// 42. Nullable 类型收窄 — if 分支
// ============================================================

// if 收窄：在 then 分支中 s 被收窄为 str
fun length(s: str?): i32 {
    if (s != null) { s.len() } else { 0 }
}
println(length("hello"))
println(length(null))

// ============================================================
// 43. Nullable 类型收窄 — match 分支
// ============================================================

fun describe(n: i32?): str {
    match n {
        null => "nothing"
        x => "got " + str(x)
    }
}
println(describe(null))
println(describe(42))

