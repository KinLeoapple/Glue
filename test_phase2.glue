// 18. ADT — 模式匹配中的守卫条件
// ============================================================

fun classify(n: i32): str {
    match n {
        0 => "zero"
        n if n < 0 => "negative"
        n if n > 100 => "large"
        _ => "small"
    }
}

println(classify(0))
println(classify(-5))
println(classify(50))
println(classify(200))

