// ============================================================
// 50. Error 子类型验证
// ============================================================

type NetworkError = Error("network error")

// 自定义错误类型可以赋值给 Error 类型的变量
fun handleErrors(x: i32): Throw<i32, Error> {
    if (x == 1) {
        throw FileError("file not found")
    }
    if (x == 2) {
        throw NetworkError("connection refused")
    }
    Ok(x)
}

val err1 = match handleErrors(1) {
    Ok(v) => v
    Error(e) => -1
}
println(err1)

val err2 = match handleErrors(2) {
    Ok(v) => v
    Error(e) => -2
}
println(err2)

val err3 = match handleErrors(3) {
    Ok(v) => v
    Error(e) => -3
}
println(err3)

// ============================================================
// 51. defer 覆盖 throw 路径
// ============================================================

var defer_throw_flag = 0
fun throwsWithDefer(): Throw<i32, Error> {
    defer defer_throw_flag = 42
    throw Error("oops")
}

val throw_result = match throwsWithDefer() {
    Ok(v) => v
    Error(e) => -1
}
println(throw_result)
println(defer_throw_flag)

