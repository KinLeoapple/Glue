type Tagged<T> = Tagged(T)

val tagged1 = Tagged(42)
val tagged2 = Tagged("label")
println(tagged1)
println(tagged2)

// ============================================================
// 36. Trait — 关联类型（类型检查验证）
// ============================================================

trait Container {
    type Item
    fun empty()
    fun insert(self, item)
    fun len(self): i32
}

// 关联类型验证：impl 必须定义 type Item = i32
impl Container<GList<i32>> {
    type Item = i32
    fun empty(): GList<i32> {
        GNil
    }
    fun insert(self, item: i32): GList<i32> {
        GCons(item, self)
    }
    fun len(self): i32 {
        glistLen(self)
    }
}

// 注：关联类型验证在类型检查阶段完成
// 运行时调用 trait 方法需要完整 vtable 支持（后续 Phase 实现）

// ============================================================
// 37. Trait 组合 — 父 Trait 继承
// ============================================================

trait Show {
    fun show(self): str
}

trait Debug extends Show {
    fun debug(self): str
}

impl Show<Ordering> {
    fun show(self): str {
        match self {
            Lt => "Lt"
            Eq => "Eq"
            Gt => "Gt"
        }
    }
}

impl Debug<Ordering> {
    fun debug(self): str {
        "Debug(" + self.show() + ")"
    }
}

println(Lt.show())
println(Eq.debug())

// ============================================================
// 38. 泛型 ADT — map 函数
// ============================================================

fun glistMap<T, U>(l: GList<T>, f): GList<U> {
    match l {
        GNil => GNil
        GCons(x, tail) => GCons(f(x), glistMap(tail, f))
    }
}

val doubled = glistMap(glist1, fun(x) { x * 2 })
println(doubled)

// ============================================================
// 39. 泛型 ADT — filter 函数
// ============================================================

fun glistFilter(l: GList<i32>, pred): GList<i32> {
    match l {
        GNil => GNil
        GCons(x, tail) => {
            val rest = glistFilter(tail, pred)
            if (pred(x)) { GCons(x, rest) } else { rest }
        }
    }
}

val evens = glistFilter(glist1, fun(x) { x % 2 == 0 })
println(evens)

// ============================================================
// 40. 综合测试 — 泛型表达式求值器
// ============================================================

type GExpr<T> =
    | Lit(T)
    | GAdd(GExpr<i32>, GExpr<i32>)

fun evalExpr(e: GExpr<i32>): i32 {
    match e {
        Lit(n) => n
        GAdd(a, b) => evalExpr(a) + evalExpr(b)
    }
}

val gexpr1 = GAdd(Lit(10), Lit(20))
println(evalExpr(gexpr1))

val gexpr2 = GAdd(GAdd(Lit(1), Lit(2)), Lit(3))
println(evalExpr(gexpr2))
