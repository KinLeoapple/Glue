// ============================================================
// 56. ADT — 二叉搜索树
// ============================================================

type BST =
    | BLeaf
    | BNode(i32, BST, BST)

fun bstInsert(t: BST, v: i32): BST {
    match t {
        BLeaf => BNode(v, BLeaf, BLeaf)
        BNode(n, left, right) => {
            if (v < n) { BNode(n, bstInsert(left, v), right) }
            else if (v > n) { BNode(n, left, bstInsert(right, v)) }
            else { t }
        }
    }
}

fun bstContains(t: BST, v: i32): bool {
    match t {
        BLeaf => false
        BNode(n, left, right) => {
            if (v == n) { true }
            else if (v < n) { bstContains(left, v) }
            else { bstContains(right, v) }
        }
    }
}

val bst = bstInsert(bstInsert(bstInsert(BLeaf, 5), 3), 8)
println(bstContains(bst, 5))
println(bstContains(bst, 3))
println(bstContains(bst, 8))
println(bstContains(bst, 7))

