// 端到端压力测试：用 Glue 实现一个小型栈式计算器 + 链表库 + 字符串处理
// 综合压测：ADT、泛型、模式匹配、递归、Throw、记录、闭包、高阶函数、trait

// ============================================================
// 泛型链表库
// ============================================================
type List<T> =
    | Nil
    | Cons(T, List<T>)

fun length<T>(l: List<T>): i32 {
    match l {
        Nil => 0
        Cons(_, tail) => 1 + length(tail)
    }
}

fun mapL<T, U>(l: List<T>, f): List<U> {
    match l {
        Nil => Nil
        Cons(x, tail) => Cons(f(x), mapL(tail, f))
    }
}

fun foldL<T>(l: List<T>, acc: i32, f): i32 {
    match l {
        Nil => acc
        Cons(x, tail) => foldL(tail, f(acc, x), f)
    }
}

fun reverseL<T>(l: List<T>): List<T> {
    fun go(remaining: List<T>, accumulated: List<T>): List<T> {
        match remaining {
            Nil => accumulated
            Cons(x, tail) => go(tail, Cons(x, accumulated))
        }
    }
    go(l, Nil)
}

fun filterL(l: List<i32>, pred): List<i32> {
    match l {
        Nil => Nil
        Cons(x, tail) => {
            val rest = filterL(tail, pred)
            if pred(x) { Cons(x, rest) } else { rest }
        }
    }
}

fun rangeL(lo: i32, hi: i32): List<i32> {
    if lo > hi { Nil } else { Cons(lo, rangeL(lo + 1, hi)) }
}

// ============================================================
// 表达式 AST + 求值（带除零错误处理）
// ============================================================
type Expr =
    | Num(i32)
    | Add(Expr, Expr)
    | Sub(Expr, Expr)
    | Mul(Expr, Expr)
    | Div(Expr, Expr)

type EvalError: Error = EvalError(msg: str) {
    override fun prefix(self): str { "eval error" }
}

fun evalExpr(e: Expr): Throw<i32, Error> {
    match e {
        Num(n) => Ok(n)
        Add(a, b) => {
            val x = evalExpr(a)?
            val y = evalExpr(b)?
            Ok(x + y)
        }
        Sub(a, b) => {
            val x = evalExpr(a)?
            val y = evalExpr(b)?
            Ok(x - y)
        }
        Mul(a, b) => {
            val x = evalExpr(a)?
            val y = evalExpr(b)?
            Ok(x * y)
        }
        Div(a, b) => {
            val x = evalExpr(a)?
            val y = evalExpr(b)?
            if y == 0 { throw EvalError("division by zero") } else { Ok(x / y) }
        }
    }
}

// ============================================================
// 二叉搜索树 (插入 + 中序遍历到 List)
// ============================================================
type Tree =
    | Leaf
    | Node(i32, Tree, Tree)

fun insert(t: Tree, v: i32): Tree {
    match t {
        Leaf => Node(v, Leaf, Leaf)
        Node(n, lo, hi) => {
            if v < n { Node(n, insert(lo, v), hi) }
            else if v > n { Node(n, lo, insert(hi, v)) }
            else { t }
        }
    }
}

fun appendL(a: List<i32>, b: List<i32>): List<i32> {
    match a {
        Nil => b
        Cons(x, tail) => Cons(x, appendL(tail, b))
    }
}

fun inorder(t: Tree): List<i32> {
    match t {
        Leaf => Nil
        Node(n, lo, hi) => appendL(inorder(lo), Cons(n, inorder(hi)))
    }
}

fun showL(l: List<i32>): str {
    match l {
        Nil => "nil"
        Cons(x, tail) => str(x) + "," + showL(tail)
    }
}

// ============================================================
// 综合驱动
// ============================================================
fun main() {
    // --- 链表: range, map, filter, fold ---
    val nums = rangeL(1, 10)
    println(length(nums))                          // 10
    println(showL(nums))                           // 1,2,...,10,nil

    val squared = mapL(nums, fun(x) { x * x })
    println(showL(squared))                        // 1,4,9,...,100,nil

    val evens = filterL(nums, fun(x) { x % 2 == 0 })
    println(showL(evens))                          // 2,4,6,8,10,nil

    val total = foldL(nums, 0, fun(acc, x) { acc + x })
    println(total)                                 // 55

    val product = foldL(rangeL(1, 5), 1, fun(acc, x) { acc * x })
    println(product)                               // 120

    println(showL(reverseL(nums)))                 // 10,9,...,1,nil

    // --- 表达式求值: (3 + 4) * 2 = 14 ---
    val e1 = Mul(Add(Num(3), Num(4)), Num(2))
    println(match evalExpr(e1) { Ok(v) => str(v), Error(err) => "err:" + err.message })  // 14

    // --- 表达式求值: 100 / (5 - 5) => div by zero ---
    val e2 = Div(Num(100), Sub(Num(5), Num(5)))
    println(match evalExpr(e2) { Ok(v) => str(v), Error(err) => "err:" + err.message() })  // err:eval error: division by zero

    // --- 嵌套表达式: ((10 - 2) * 3) / 4 = 6 ---
    val e3 = Div(Mul(Sub(Num(10), Num(2)), Num(3)), Num(4))
    println(match evalExpr(e3) { Ok(v) => str(v), Error(err) => "err:" + err.message() })  // 6

    // --- BST: 插入乱序 → 中序得有序 ---
    var tree = Leaf
    for v in [5, 3, 8, 1, 4, 7, 9, 2, 6] {
        tree = insert(tree, v)
    }
    println(showL(inorder(tree)))                  // 1,2,3,4,5,6,7,8,9,nil

    // --- 闭包计数器 + 链表生成 ---
    var seen: i32[] = []
    for x in [3, 1, 4, 1, 5, 9, 2, 6] {
        if !seen.contains(x) {
            seen = seen ++ [x]
        }
    }
    println(seen)                                  // dedup: [3,1,4,5,9,2,6]
    println(seen.len())                            // 7

    // --- 字符串构建 ---
    var msg = ""
    for w in ["Glue", "is", "working"] {
        msg = msg + w + " "
    }
    println(msg)                                   // Glue is working

    println("stress: All tests passed!")
}
