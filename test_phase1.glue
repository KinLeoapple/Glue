// ============================================================
// 73. Throw — 多分支验证
// ============================================================

fun validateAge(age: i32): Throw<i32, Error> {
    if (age < 0) { throw Error("age cannot be negative") }
    if (age > 150) { throw Error("age too large") }
    Ok(age)
}

val age1 = match validateAge(25) {
    Ok(v) => v
    Error(e) => -1
}
println(age1)

val age2 = match validateAge(-1) {
    Ok(v) => v
    Error(e) => -1
}
println(age2)

val age3 = match validateAge(200) {
    Ok(v) => v
    Error(e) => -1
}
println(age3)

