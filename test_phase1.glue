// 7. defer
// ============================================================
var counter = 0
{
    counter = 1
    defer counter = 10
    println(counter)
}
println(counter)

// 多个 defer LIFO 顺序
var order = ""
{
    defer order = order + "A"
    defer order = order + "B"
    defer order = order + "C"
}
println(order)

// ============================================================
// 8. TCO - 尾递归
// ============================================================
fun sum(n: i32, acc: i32): i32 {
    if (n == 0) { acc } else { sum(n - 1, acc + n) }
}
println(sum(1000, 0))

// TCO - 斐波那契（非尾递归，验证 TCO 不误优化）
fun fib(n: i32): i32 {
    if (n <= 1) { n } else { fib(n - 1) + fib(n - 2) }
}
println(fib(10))

