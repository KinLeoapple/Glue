// for-loop / iterator boundaries (regression)

fun mkArray(): i32[] { [10, 20, 30] }

fun main() {
    // ---- empty sources iterate zero times ----
    var s = 0i32
    for x in [] { s = s + x }
    println(s)                  // 0
    for i in 5..5 { s = s + i }
    println(s)                  // 0 (empty range)

    // ---- range variants ----
    var a = 0i32
    for i in 1..=3 { a = a + i }
    println(a)                  // 6 (inclusive)
    var b = 0i32
    for i in 1..3 { b = b + i }
    println(b)                  // 3 (exclusive)
    var c = 0i32
    for i in 5..1 { c = c + i }
    println(c)                  // 0 (reversed = empty)
    var d = 0i32
    for i in 3..=3 { d = d + i }
    println(d)                  // 3 (single element)

    // ---- string iterates by char (unicode scalar) ----
    var n = 0
    for ch in "héllo" { n = n + 1 }
    println(n)                  // 5
    var e = 0
    for ch in "" { e = e + 1 }
    println(e)                  // 0

    // ---- break / continue ----
    var bsum = 0i32
    for i in 1..=10 { if i > 3 { break } bsum = bsum + i }
    println(bsum)               // 6
    var csum = 0i32
    for i in 1..=5 { if i % 2 == 0 { continue } csum = csum + i }
    println(csum)               // 9 (1+3+5)

    // ---- nested loops, break affects inner only ----
    var cnt = 0i32
    for i in 1..=3 {
        for j in 1..=3 {
            if j == 2 { break }
            cnt = cnt + 1
        }
    }
    println(cnt)                // 3

    // ---- for over various sources ----
    var rsum = 0i32
    for p in [(x: 1), (x: 2), (x: 3)] { rsum = rsum + p.x }
    println(rsum)               // 6
    var ccat = 0i32
    for x in [1, 2] ++ [3, 4] { ccat = ccat + x }
    println(ccat)               // 10
    var fsum = 0i32
    for x in mkArray() { fsum = fsum + x }
    println(fsum)               // 60

    // ---- range loop variable participates in wider arithmetic ----
    for i in 1..=3 { println(i * 1000) }   // 1000, 2000, 3000

    println("edge_iterators: All tests passed!")
}
