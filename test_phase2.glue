// ============================================================
// 30. 泛型 ADT — 泛型列表
// ============================================================

type GList<T> =
    | GNil
    | GCons(T, GList<T>)

val glist1 = GCons(10, GCons(20, GCons(30, GNil)))
val glist2 = GCons("a", GCons("b", GCons("c", GNil)))

fun glistLen(l: GList<i32>): i32 {
    match l {
        GNil => 0
        GCons(_, tail) => 1 + glistLen(tail)
    }
}
println(glistLen(glist1))
println(glistLen(GNil))

// ============================================================
// 31. 泛型 ADT — 泛型 Pair 记录
// ============================================================

type GPair<A, B> = GPair(first: A, second: B)

val gp1 = GPair(1, "one")
val gp2 = GPair(true, 42)
println(gp1.first)
println(gp1.second)
println(gp2.first)
println(gp2.second)

// ============================================================
// 32. 泛型函数 — 泛型 Trait Bound
// ============================================================

fun genericMax<T>(a: T, b: T): T with Comparable<T> {
    match compare(a, b) {
        Lt => b
        Eq => a
        Gt => a
    }
}

println(genericMax(3, 7))
println(genericMax(10, 2))

// ============================================================
// 33. 泛型 ADT — Nullable 与泛型交互
// ============================================================

fun glistHead<T>(l: GList<T>): T? {
    match l {
        GNil => null
        GCons(x, _) => x
    }
}

println(glistHead(glist1))
println(glistHead(GNil))

// ============================================================
// 34. 泛型 ADT — 泛型树
// ============================================================

type GTree<T> =
    | GLeaf
    | GNode(T, GTree<T>, GTree<T>)

val gtree = GNode(5, GNode(3, GLeaf, GLeaf), GNode(8, GLeaf, GLeaf))

fun gtreeSum(t: GTree<i32>): i32 {
    match t {
        GLeaf => 0
        GNode(v, left, right) => v + gtreeSum(left) + gtreeSum(right)
    }
}
println(gtreeSum(gtree))

