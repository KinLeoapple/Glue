// ============================================================
// 50. ADT — 表达式求值器扩展（减法和除法）
// ============================================================

type Expr2 =
    | Num2(i32)
    | Add2(Expr2, Expr2)
    | Sub2(Expr2, Expr2)
    | Mul2(Expr2, Expr2)

fun eval2(e: Expr2): i32 {
    match e {
        Num2(n) => n
        Add2(a, b) => eval2(a) + eval2(b)
        Sub2(a, b) => eval2(a) - eval2(b)
        Mul2(a, b) => eval2(a) * eval2(b)
    }
}

// (10 - 3) * 2 = 14
val e2 = Mul2(Sub2(Num2(10), Num2(3)), Num2(2))
println(eval2(e2))

