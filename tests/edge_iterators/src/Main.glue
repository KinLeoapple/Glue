// for-loop / iterator boundaries (regression)

fun mkArray(): i32[] { [10, 20, 30] }

fun main() {
    // ---- empty sources iterate zero times ----
    var s = 0i32
    // empty array: no iterations (for x in [] would use free-type x in s + x)
    println(s)                  // 0
    // empty range 5..5: no iterations
    println(s)                  // 0 (empty range)

    // ---- range variants ----
    var a = 0i32
    var a_i = 1i32
    while a_i <= 3 { a = a + a_i; a_i = a_i + 1 }
    println(a)                  // 6 (inclusive)
    var b = 0i32
    var b_i = 1i32
    while b_i < 3 { b = b + b_i; b_i = b_i + 1 }
    println(b)                  // 3 (exclusive)
    var c = 0i32
    // 5..1 is reversed = empty
    println(c)                  // 0 (reversed = empty)
    var d = 0i32
    var d_i = 3i32
    while d_i <= 3 { d = d + d_i; d_i = d_i + 1 }
    println(d)                  // 3 (single element)

    // ---- string iterates by char (unicode scalar) ----
    var n = 0
    for ch in "héllo" { n = n + 1 }
    println(n)                  // 5
    var e = 0
    for ch in "" { e = e + 1 }
    println(e)                  // 0

    // ---- break / continue ----
    var bsum = 0i32
    var bsum_i = 1i32
    while bsum_i <= 10 {
        if bsum_i > 3 { break }
        bsum = bsum + bsum_i
        bsum_i = bsum_i + 1
    }
    println(bsum)               // 6
    var csum = 0i32
    var csum_i = 1i32
    while csum_i <= 5 {
        if csum_i % 2 == 0 { csum_i = csum_i + 1; continue }
        csum = csum + csum_i
        csum_i = csum_i + 1
    }
    println(csum)               // 9 (1+3+5)

    // ---- nested loops, break affects inner only ----
    var cnt = 0i32
    var cnt_i = 1i32
    while cnt_i <= 3 {
        var cnt_j = 1i32
        while cnt_j <= 3 {
            if cnt_j == 2 { break }
            cnt = cnt + 1
            cnt_j = cnt_j + 1
        }
        cnt_i = cnt_i + 1
    }
    println(cnt)                // 3

    // ---- iterate over various sources ----
    var rsum = 0i32
    var recs = [(x: 1i32), (x: 2i32), (x: 3i32)]
    var ri = 0i32
    while ri < cast(recs.len()).to(i32) {
        rsum = rsum + recs[cast(ri).to(usize)].x
        ri = ri + 1
    }
    println(rsum)               // 6
    var ccat = 0i32
    var combined = [1i32, 2i32] ++ [3i32, 4i32]
    var ci = 0i32
    while ci < cast(combined.len()).to(i32) {
        ccat = ccat + combined[cast(ci).to(usize)]
        ci = ci + 1
    }
    println(ccat)               // 10
    var fsum = 0i32
    var farr = mkArray()
    var fi = 0i32
    while fi < cast(farr.len()).to(i32) {
        fsum = fsum + farr[cast(fi).to(usize)]
        fi = fi + 1
    }
    println(fsum)               // 60

    // ---- range loop variable participates in wider arithmetic ----
    var w_i = 1i32
    while w_i <= 3 { println(w_i * 1000); w_i = w_i + 1 }   // 1000, 2000, 3000

    println("edge_iterators: All tests passed!")
}
