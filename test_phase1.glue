// Phase 1 功能验证
// 严格按照语言设计规范 Phase 1 表格：
//   基础类型、Nullable、Throw、Error、Type Alias + Newtype、类型转换、
//   相等性、Panic、defer、整数溢出、浮点数、闭包捕获、var 与值语义、
//   main 签名、数组、Range、字符串插值、函数参数、尾调用优化、记录

// ============================================================
// 类型声明（顶层）—— 仅 Phase 1 类型
// ============================================================

// 自定义错误类型（Error 子类型）
type FileError = Error("file error")
type NetworkError = Error("network error")
type ParseError = Error("parse error")
type DbError = Error("database error")

// Newtype — 零开销包装
type UserId = UserId(i32)
type Celsius = Celsius(f64)
type Kelvin = Kelvin(f64)
type Email = Email(str)
type Grade = Grade(i32)

// Newtype — 记录式（命名字段）
type Point = Point(x: i32, y: i32)
type Config = Config(host: str, port: i32)
type Address = Address(city: str)
type User = User(name: str, addr: Address?)
type Addr = Addr(city: str, zip: i32)
type Person = Person(name: str, addr: Addr)
type Pt2 = Pt2(x: i32, y: i32)
type Rect = Rect(w: f64, h: f64)
type Shape2 = Shape2(rect: Rect, label: str)
type Inner2 = Inner2(value: i32)
type Outer2 = Outer2(inner: Inner2, label: str)

// Newtype — 嵌套 Nullable
type Deep = Deep(v: i32)
type Mid = Mid(d: Deep?)
type Top = Top(m: Mid?)

// Type Alias — 类型别名
type Name = str
type Age = i32
type Score = i32

// ============================================================
// 函数声明（顶层）
// ============================================================

// Throw — throw 语句
fun mightFail(x: i32): Throw<i32, Error> {
    if (x < 0) {
        throw Error("negative value")
    }
    Ok(x * 2)
}

// TCO — 尾递归
fun sum(n: i32, acc: i32): i32 {
    if (n == 0) { acc } else { sum(n - 1, acc + n) }
}

// 递归 — 非尾递归（验证 TCO 不误优化）
fun fib(n: i32): i32 {
    if (n <= 1) { n } else { fib(n - 1) + fib(n - 2) }
}

// var 参数
fun modify(data: var i32): i32 {
    data = data + 1
    data
}

// ? 传播 — Nullable
fun maybeNull(): i32? {
    null
}

fun useNullable(): i32? {
    val v = maybeNull()?
    v + 1
}

// 函数作为一等公民
fun apply(f, x): i32 {
    f(x)
}

// 嵌套函数
fun outer_fn(x: i32): i32 {
    fun inner(y: i32): i32 {
        x + y
    }
    inner(10)
}

// return 语句
fun earlyReturn(x: i32): i32 {
    if (x > 10) { return 100 }
    x
}

// ? 传播 — Throw
fun safeDiv(a: i32, b: i32): Throw<i32, Error> {
    if (b == 0) {
        throw Error("division by zero")
    }
    Ok(a / b)
}

// 多层 ? 传播 — Nullable
fun getFirst(): i32? { null }
fun getSecond(): i32? { 42 }

fun chain(): i32? {
    val a = getFirst()?
    val b = getSecond()?
    a + b
}

fun chain2(): i32? {
    val b = getSecond()?
    b + 1
}

// Nullable 类型收窄 — if 分支
fun length(s: str?): i32 {
    if (s != null) { s.len() } else { 0 }
}

// Nullable 类型收窄 — match 分支
fun describe(n: i32?): str {
    match n {
        null => "nothing"
        x => "got " + str(x)
    }
}

// Error 子类型验证
fun handleErrors(x: i32): Throw<i32, Error> {
    if (x == 1) {
        throw FileError("file not found")
    }
    if (x == 2) {
        throw NetworkError("connection refused")
    }
    Ok(x)
}

// defer 覆盖 throw 路径
var defer_throw_flag: i32 = 0

fun throwsWithDefer(): Throw<i32, Error> {
    defer defer_throw_flag = 42
    throw Error("oops")
}

// Nullable 作为函数返回值
fun findUser(id: i32): str? {
    if (id == 1) { "Alice" } else { null }
}

// Nullable 嵌套在 Throw 中
fun findOrError(id: i32): Throw<str?, Error> {
    if (id < 0) {
        throw Error("invalid id")
    }
    if (id == 0) {
        Ok(null)
    } else {
        Ok(findUser(id))
    }
}

// 递归与 TCO — 阶乘（非尾递归）
fun factorial(n: i32): i32 {
    if (n <= 1) { 1 } else { n * factorial(n - 1) }
}

// 尾递归倒计数
fun countdown(n: i32): i32 {
    if (n == 0) { 0 } else { countdown(n - 1) }
}

// match — 字面量模式
fun classify(n: i32): str {
    match n {
        0 => "zero"
        1 => "one"
        _ => "other"
    }
}

// 布尔模式
fun boolMatch(b: bool): str {
    match b {
        true => "yes"
        false => "no"
    }
}

// 空值安全操作综合
fun loadConfig(): Config? {
    null
}

// Throw 链式 ? 传播
fun step1(): Throw<i32, Error> {
    Ok(10)
}

fun step2(x: i32): Throw<i32, Error> {
    if (x > 5) { Ok(x * 2) } else { throw Error("too small") }
}

fun step3(x: i32): Throw<i32, Error> {
    if (x < 100) { Ok(x + 1) } else { throw Error("too large") }
}

fun pipeline(): Throw<i32, Error> {
    val a = step1()?
    val b = step2(a)?
    val c = step3(b)?
    c
}

// 多个 defer 和 return 交互
fun deferReturn(): i32 {
    var result: i32 = 0
    {
        defer result = result + 10
        result = 5
    }
    result
}

// 单位值
fun doNothing(): () { }

// Nullable — 函数参数和返回值
fun defaultIfNull(value: i32?, default: i32) {
    value ?? default
}

fun wrapInNullable(x: i32): i32? { x }

// Throw — 多分支验证
fun validateAge(age: i32): Throw<i32, Error> {
    if (age < 0) { throw Error("age cannot be negative") }
    if (age > 150) { throw Error("age too large") }
    Ok(age)
}

// 闭包 — 闭包作为函数参数传递
fun transform(value: i32, f): i32 { f(value) }

// 记录类型 — 记录作为函数参数和返回值
fun makePoint(x: i32, y: i32): Point { Point(x, y) }
fun pointSum(p: Point): i32 { p.x + p.y }

// Type Alias — 别名在函数签名中使用
fun isAdult(age: i32): bool { age >= 18 }

// match — 字符串和字面量模式
fun direction(s: str): i32 {
    match s {
        "north" => 1
        "south" => 2
        "east" => 3
        "west" => 4
        _ => 0
    }
}

// 嵌套 if-else 表达式
fun classifyNum(x: i32): str {
    if (x < 0) {
        "negative"
    } else if (x == 0) {
        "zero"
    } else if (x < 100) {
        "small"
    } else {
        "large"
    }
}

// 单位值更多场景
fun sideEffect(): () {
    println("side effect")
}

// 函数组合
fun compose(f, g, x): i32 { f(g(x)) }

// Error — 多种错误类型
fun parseOrThrow(s: str): Throw<i32, Error> {
    if (s == "valid") { Ok(42) }
    else if (s == "parse_fail") { throw ParseError("invalid syntax") }
    else { throw Error("unknown error") }
}

// Nullable + Throw 组合
fun findOrError2(id: i32): Throw<str, Error> {
    if (id < 0) {
        throw Error("invalid id")
    }
    if (id == 0) {
        Ok("")
    } else {
        Ok("user" + str(id))
    }
}

// Throw — Ok 和 throw 混合
fun maybeThrow(cond: bool): Throw<i32, Error> {
    if (cond) { Ok(100) } else { throw Error("failed") }
}

// 闭包 — 嵌套闭包
fun outer_fn2(x: i32): i32 {
    fun inner(y: i32): i32 { x + y }
    inner(10)
}

// 综合测试 — Nullable + Throw + 闭包
fun safeCompute(x: i32): Throw<i32, Error> {
    if (x < 0) { throw Error("negative") }
    Ok(x * 2)
}

// 多层 ? 传播 — Throw 链
fun step1b(): Throw<i32, Error> { Ok(10) }
fun step2b(x: i32): Throw<i32, Error> {
    if (x > 5) { Ok(x * 2) } else { throw Error("too small") }
}

fun pipeline2(): Throw<i32, Error> {
    val a = step1b()?
    val b = step2b(a)?
    b + 1
}

// 嵌套 match
fun nestedMatch(x: i32, y: i32): str {
    match x {
        0 => "zero"
        _ => match y {
            0 => "x nonzero, y zero"
            _ => "both nonzero"
        }
    }
}

// defer — 与 throw 交互
var defer_throw_val: i32 = 0

fun throwsWithDefer2(): Throw<i32, Error> {
    defer defer_throw_val = 99
    throw Error("oops2")
}

// Type Alias + 函数
fun passThreshold(s: i32): bool { s >= 60 }

// 嵌套函数 — 多层嵌套
fun outer2(x: i32): i32 {
    fun middle(y: i32): i32 {
        fun innermost(z: i32): i32 {
            x + y + z
        }
        innermost(100)
    }
    middle(10)
}

// 嵌套函数访问外层局部变量
fun makeCounter(start: i32): i32 {
    var count = start
    fun increment(): i32 {
        count = count + 1
        count
    }
    increment()
    increment()
    increment()
}

// 嵌套函数 — 嵌套调用
fun addAndDouble(a: i32, b: i32): i32 {
    fun double(x: i32): i32 { x * 2 }
    double(a + b)
}

// 嵌套递归函数
fun outer3(n: i32): i32 {
    fun helper(acc: i32, i: i32): i32 {
        if (i > n) { acc } else { helper(acc + i, i + 1) }
    }
    helper(0, 1)
}

// defer — defer 在 return 路径执行
var defer_ret_flag: i32 = 0

fun deferReturn2(): i32 {
    defer defer_ret_flag = 100
    42
}

// TCO — 单函数递归
fun sumTCO(n: i32, acc: i32): i32 {
    if (n == 0) { acc } else { sumTCO(n - 1, acc + n) }
}

// Throw — throw 后 defer 仍执行
var defer_throw_val2: i32 = 0

fun throwsWithDefer3(): Throw<i32, Error> {
    defer defer_throw_val2 = 55
    throw Error("defer test")
}

// 函数作为参数传递给高阶函数
fun applyTwice(f, x) { f(f(x)) }

// Newtype — newtype 内部值提取
fun extractGrade(gr: Grade): i32 {
    match gr {
        Grade(v) => v
    }
}

// Nullable — 三元替代（if-else 表达式）
fun clamp(v: i32, min_v: i32, max_v: i32): i32 {
    if (v < min_v) { min_v }
    else if (v > max_v) { max_v }
    else { v }
}

// 守卫条件与或模式组合
fun classifyNum2(n: i32): str {
    match n {
        0 => "zero"
        1 | 2 | 3 => "small"
        n if n < 0 => "negative"
        _ => "other"
    }
}

// 记录模式解构
fun quadrant(p: Pt2): str {
    match p {
        Pt2(0, 0) => "origin"
        Pt2(x, y) if x > 0 && y > 0 => "Q1"
        Pt2(x, y) if x < 0 && y > 0 => "Q2"
        Pt2(x, y) if x < 0 && y < 0 => "Q3"
        Pt2(x, y) if x > 0 && y < 0 => "Q4"
        _ => "axis"
    }
}

// Nullable — if-else 返回 Nullable
fun safeDiv2(a: i32, b: i32): i32? {
    if (b == 0) { null } else { a / b }
}

// Throw — 链式 ? 传播更多场景
fun parsePositive(s: str): Throw<i32, Error> {
    if (s == "valid") { Ok(42) }
    else { throw Error("parse error") }
}

fun doubleIfPositive(n: i32): Throw<i32, Error> {
    if (n > 0) { Ok(n * 2) } else { throw Error("not positive") }
}

fun parseAndDouble(s: str): Throw<i32, Error> {
    val n = parsePositive(s)?
    doubleIfPositive(n)?
}

// 闭包 — 闭包作为参数传递给高阶函数
fun applyTwice2(f, x) { f(f(x)) }

// 动态数组 — map/filter 模式
fun mapArray(arr, f) {
    var result = []
    for item in arr {
        result = result.push(f(item))
    }
    result
}

fun filterArray(arr, pred) {
    var result = []
    for item in arr {
        if (pred(item)) {
            result = result.push(item)
        }
    }
    result
}

// while — 欧几里得算法迭代版
fun gcdIter(a: i32, b: i32): i32 {
    var x = a
    var y = b
    while y != 0 {
        val temp = y
        y = x % y
        x = temp
    }
    x
}

// match — 守卫条件
fun fizzbuzz(n: i32): str {
    match n {
        n if n % 15 == 0 => "FizzBuzz"
        n if n % 3 == 0 => "Fizz"
        n if n % 5 == 0 => "Buzz"
        _ => str(n)
    }
}

// 递归 — 更复杂的递归
fun gcd(a: i32, b: i32): i32 {
    if (b == 0) { a } else { gcd(b, a % b) }
}

// 递归 — 斐波那契更多
fun fib2(n: i32): i32 {
    if (n <= 1) { n } else { fib2(n - 1) + fib2(n - 2) }
}

// 函数 — 多参数
fun add3(a: i32, b: i32, c: i32): i32 { a + b + c }

// Nullable — match 中 null 模式
fun describeNullable(n: i32?): str {
    match n {
        null => "is null"
        0 => "is zero"
        _ => "is positive"
    }
}

// Throw — Ok 包含值
fun maybeNullResult(x: i32): Throw<i32, Error> {
    if (x == 0) { Ok(-1) }
    else { Ok(x) }
}

// 闭包 — 闭包作为参数传递给高阶函数
fun applyTwice3(f, x) { f(f(x)) }


// ============================================================
// 测试函数
// ============================================================

fun test1(): () {
// ============================================================
// 1. 基础类型
// ============================================================
val a = 42
val b = 3.14
val c = true
val ch = 'A'
println(a)
println(b)
println(c)
println(ch)

// 整数类型后缀
val i8_val = 127i8
val u8_val = 255u8
val i64_val = 9999999999i64
println(i8_val)
println(u8_val)
println(i64_val)

// ============================================================
// 2. Nullable
// ============================================================
val x: i32? = null
val y: i32 = x ?? 99
println(y)

val z: i32? = 10
val w: i32 = z ?? 99
println(w)

// 非空断言 !
val nz: i32? = 42
val nv = nz!
println(nv)

// 安全访问 ?.
val nullable_point: (x: i32, y: i32)? = null
val safe_x = nullable_point?.x
println(safe_x)

// ============================================================
// 3. Ok/Error 和 Throw
// ============================================================
val result = Ok(42)
println(result)

val err = Error("something failed")
println(err)

// throw 语句
println(mightFail(5))

// ============================================================
// 4. match Ok/Error
// ============================================================
val r = match Ok(100) {
    Ok(v) => v + 1
    Error(e) => 0
}
println(r)

// ============================================================
// 5. 自定义错误类型
// ============================================================
val fe = FileError("config.json not found")
println(fe)

// ============================================================
// 6. 字符串插值
// ============================================================
val name = "Glue"
println("Hello, {name}!")
// 转义花括号
println("Use {{ and }} for braces")

// ============================================================
// 7. defer
// ============================================================
var counter: i32 = 0
{
    counter = 1
    defer counter = 10
    println(counter)
}
println(counter)

// 多个 defer LIFO 顺序
var order = ""
{
    defer order = order + "A"
    defer order = order + "B"
    defer order = order + "C"
}
println(order)

// ============================================================
// 8. TCO — 尾递归
// ============================================================
println(sum(1000, 0))
println(fib(10))

// ============================================================
// 9. 数组固定大小
// ============================================================
val arr: i32[3] = [10, 20, 30]
println(arr)
println(arr.len())
println(arr[0])
println(arr[1])
println(arr[2])

// ============================================================
// 10. for 循环迭代数组
// ============================================================
var total: i32 = 0
for item in arr {
    total = total + item
}
println(total)

}

fun test2(): () {
// ============================================================
// 11. Error.message 属性访问
// ============================================================
val e = Error("not found")
println(e.message)

// ============================================================
// 12. match Error 中访问 .message
// ============================================================
val r2 = match Error("disk full") {
    Ok(v) => "ok"
    Error(err) => err.message
}
println(r2)

// ============================================================
// 13. 自定义错误类型的 .message
// ============================================================
val fe2 = FileError("read failed")
val msg = match fe2 {
    Ok(v) => "ok"
    Error(err) => err.message
}
println(msg)

// ============================================================
// 14. Range 迭代
// ============================================================
var range_sum: i32 = 0
for i in 1..=5 {
    range_sum = range_sum + i
}
println(range_sum)

// 排除范围
var range_sum2: i32 = 0
for i in 1..5 {
    range_sum2 = range_sum2 + i
}
println(range_sum2)

// ============================================================
// 15. 类型转换
// ============================================================
val big: i64 = 100
val small = i32(big)
println(small)

val f = f64(42)
println(f)

// ============================================================
// 16. 闭包和 Lambda
// ============================================================
val add = fun(a, b) { a + b }
println(add(3, 4))

val x10 = 10
val add_x = fun(y) { x10 + y }
println(add_x(5))

// 闭包修改外部 var
var outer: i32 = 0
val increment = fun() { outer = outer + 1 }
increment()
increment()
increment()
println(outer)

// ============================================================
// 17. var 参数
// ============================================================
val modified = modify(100)
println(modified)

// ============================================================
// 18. if-else 表达式
// ============================================================
val cond = if (true) { 1 } else { 2 }
println(cond)

val cond2 = if (false) { "a" } else { "b" }
println(cond2)

// ============================================================
// 19. while 循环
// ============================================================
var w_count: i32 = 0
var w_sum: i32 = 0
while w_count < 5 {
    w_sum = w_sum + w_count
    w_count = w_count + 1
}
println(w_sum)

}

fun test3(): () {
// ============================================================
// 20. 一元运算
// ============================================================
println(-42)
println(!true)

// ============================================================
// 21. 二元运算
// ============================================================
println(10 + 3)
println(10 - 3)
println(10 * 3)
println(10 / 3)
println(10 % 3)
println(true && false)
println(true || false)

// ============================================================
// 22. 相等性
// ============================================================
println(42 == 42)
println(42 != 43)
println("hello" == "hello")

// eq 结构相等
println(eq(42, 42))
println(eq("abc", "abc"))

// ============================================================
// 23. 字符串操作
// ============================================================
println("hello".len())
val s = "abc"
println(s[0])
println(s[1])
println(s[2])

// ============================================================
// 24. 记录类型
// ============================================================
val point = (x: 1, y: 2)
println(point.x)
println(point.y)

// ============================================================
// 25. Type Alias / Newtype
// ============================================================
val uid = UserId(42)
println(uid)

// ============================================================
// 26. ? 传播 Nullable
// ============================================================
val use_result = useNullable()
println(use_result)

// ============================================================
// 27. loop 和 break
// ============================================================
var loop_count = 0
var loop_sum = 0
loop {
    if (loop_count >= 5) { break }
    loop_sum = loop_sum + loop_count
    loop_count = loop_count + 1
}
println(loop_sum)

// ============================================================
// 28. for 循环 continue
// ============================================================
var skip_sum: i32 = 0
for i in 1..=10 {
    if (i % 2 == 0) { continue }
    skip_sum = skip_sum + i
}
println(skip_sum)

// ============================================================
// 29. 函数作为一等公民
// ============================================================
val double = fun(n) { n * 2 }
println(apply(double, 5))

// ============================================================
// 30. 嵌套函数
// ============================================================
println(outer_fn(5))

// ============================================================
// 31. return 语句
// ============================================================
println(earlyReturn(5))
println(earlyReturn(20))

}

fun test4(): () {
// ============================================================
// 32. ? 传播 — Throw 类型
// ============================================================
val divResult = match safeDiv(10, 3) {
    Ok(v) => v
    Error(e) => -1
}
println(divResult)

val divError = match safeDiv(10, 0) {
    Ok(v) => v
    Error(e) => -1
}
println(divError)

// ============================================================
// 33. 多层 ? 传播 Nullable
// ============================================================
println(chain())
println(chain2())

// ============================================================
// 34. Nullable 类型收窄 — if 分支
// ============================================================
println(length("hello"))
println(length(null))

// ============================================================
// 35. Nullable 类型收窄 — match 分支
// ============================================================
println(describe(null))
println(describe(42))

// ============================================================
// 36. Nullable — 链式 ?.
// ============================================================
val u1: User? = User("Alice", Address("Beijing"))
val u2: User? = null

println(u1?.name)
println(u1?.addr?.city)
println(u2?.name)

// ============================================================
// 37. Nullable — 链式 ??
// ============================================================
val a1: i32? = null
val a2: i32? = null
val a3: i32? = 42

val chain_elvis: i32 = a1 ?? a2 ?? a3 ?? 0
println(chain_elvis)

val chain_elvis2: i32 = a1 ?? a2 ?? 99
println(chain_elvis2)

// ============================================================
// 38. 所有整数类型
// ============================================================
val v_i8: i8 = 127
val v_i16: i16 = 32767
val v_i32: i32 = 2147483647
val v_i64: i64 = 9999999999i64
val v_i128: i128 = 999999999999999999i128

val v_u8: u8 = 255
val v_u16: u16 = 65535
val v_u32: u32 = 4294967295u32
val v_u64: u64 = 9999999999u64
val v_u128: u128 = 999999999999999999u128

println(v_i8)
println(v_i16)
println(v_i32)
println(v_i64)
println(v_i128)
println(v_u8)
println(v_u16)
println(v_u32)
println(v_u64)
println(v_u128)

// ============================================================
// 39. 浮点类型 f32 / f64
// ============================================================
val f32_val: f32 = 3.14
val f64_val: f64 = 2.718281828
println(f32_val)
println(f64_val)

// ============================================================
// 40. 类型转换 — widening/narrowing
// ============================================================
// widening
val i8_to_i32 = i32(v_i8)
val i32_to_i64 = i64(v_i32)
val i32_to_f64 = f64(v_i32)
println(i8_to_i32)
println(i32_to_i64)
println(i32_to_f64)

// narrowing（合法范围内）
val small_i64: i64 = 100
val i64_to_i32 = i32(small_i64)
println(i64_to_i32)

// ============================================================
// 41. Type Alias
// ============================================================
val my_name: Name = "Glue"
println(my_name)

val my_age: Age = 25
println(my_age)

}

